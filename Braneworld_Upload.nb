Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"SWSHSSpectral", "[", 
     RowBox[{
     "s_Integer", ",", " ", "l_Integer", ",", " ", "m_Integer", ",", " ", 
      "\[Gamma]_", ",", " ", 
      RowBox[{"opts", ":", 
       RowBox[{"OptionsPattern", "[", "]"}]}]}], "]"}], " ", ":=", "\n", " ", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "lmin", ",", " ", "nUp", ",", " ", "nDown", ",", " ", "A", ",", " ", 
        "esys", ",", "evec", ",", "eval", ",", "sign", ",", "pos"}], "}"}], 
      ",", "\n", "  ", 
      RowBox[{"(*", " ", 
       RowBox[{"FIXME", ":", " ", 
        RowBox[{"Improve", " ", "the", " ", "estimate", " ", "of", " ", 
         RowBox[{"nmax", ".", " ", "It"}], " ", "should", " ", "depend", " ", 
         "on", " ", "the", " ", "accuarcy", " ", 
         RowBox[{"sought", "."}]}]}], " ", "*)"}], "\n", "  ", 
      RowBox[{
       RowBox[{"Switch", "[", 
        RowBox[{
         RowBox[{"OptionValue", "[", "\"\<NumTerms\>\"", "]"}], ",", "\n", 
         "   ", "Automatic", ",", "\n", "    ", 
         RowBox[{
          RowBox[{"nUp", " ", "=", " ", 
           RowBox[{
            RowBox[{"Ceiling", "[", 
             RowBox[{"Abs", "[", 
              RowBox[{
               RowBox[{"3", "/", "2"}], "\[Gamma]"}], "]"}], "]"}], "+", 
            "5"}]}], ";", "\n", "    ", 
