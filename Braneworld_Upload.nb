Cell[BoxData[
 RowBox[{
  RowBox[{"SpinWeightedSpheroidalHarmonicS", " ", "/:", " ", "\n", "  ", 
   RowBox[{"Series", "[", 
    RowBox[{
     RowBox[{"SpinWeightedSpheroidalHarmonicS", "[", 
      RowBox[{
      "s_", ",", " ", "l_", ",", " ", "m_", ",", " ", "\[Gamma]_", ",", " ", 
