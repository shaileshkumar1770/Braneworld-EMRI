Cell[BoxData[
 RowBox[{"SpinWeightedSpheroidalEigenvalue", " ", "/:", " ", "\n", "  ", 
  RowBox[{"Series", "[", 
   RowBox[{
    RowBox[{"SpinWeightedSpheroidalEigenvalue", "[", 
     RowBox[{
      RowBox[{"s_", "?", "NumberQ"}], ",", " ", 
      RowBox[{"l_", "?", "NumberQ"}], ",", " ", 
      RowBox[{"m_", "?", "NumberQ"}], ",", " ", "\[Gamma]_"}], "]"}], ",", 
    " ", 
    RowBox[{"{", 
     RowBox[{"\[Gamma]_", ",", " ", "\[Infinity]", ",", " ", "order_"}], 
     "}"}]}], "]"}], " ", ":=", "\n", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "slm", ",", "z0", ",", "q", ",", "aFgen", ",", "AFgen", ",", "Asgen", 
      ",", "\[Delta]gen", ",", "\[Nu]gen", ",", "RecRelgen", ",", "n", ",", 
      "c", ",", "p", ",", "Serngen", ",", "Asum", ",", "sElm", ",", 
      "s\[Lambda]lm", ",", "res"}], "}"}], ",", "\n", "  ", 
    RowBox[{
     RowBox[{
      RowBox[{"aFgen", "[", 
       RowBox[{"0", ",", "_"}], "]"}], "=", "0"}], ";", "\n", "  ", 
     RowBox[{
      RowBox[{"aFgen", "[", 
       RowBox[{"0", ",", "0"}], "]"}], "=", "1"}], ";", "\n", "\n", "  ", 
     RowBox[{
      RowBox[{"AFgen", "[", "0", "]"}], "=", "1"}], ";", "\n", "  ", 
     RowBox[{
      RowBox[{"AFgen", "[", "r_", "]"}], "=", 
      RowBox[{
       RowBox[{"AFgen", "[", "0", "]"}], 
       RowBox[{"Sum", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"aFgen", "[", 
           RowBox[{"r", ",", "k"}], "]"}], 
          RowBox[{"c", "^", 
           RowBox[{"-", "k"}]}]}], ",", 
         RowBox[{"{", 
          RowBox[{"k", ",", 
           RowBox[{"Abs", "[", "r", "]"}], ",", " ", 
           RowBox[{"order", "+", "1"}]}], "}"}]}], "]"}]}]}], ";", "\n", "  ",
      "\n", "  ", 
     RowBox[{"Asgen", "=", 
      RowBox[{"Sum", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"\[Delta]gen", "[", "k", "]"}], 
         RowBox[{"c", "^", 
          RowBox[{"-", "k"}]}]}], ",", " ", 
        RowBox[{"{", 
         RowBox[{"k", ",", " ", "1", ",", " ", 
          RowBox[{"order", "+", "1"}]}], "}"}]}], "]"}]}], ";", "\n", "  ", 
     RowBox[{"\[Nu]gen", "=", 
      RowBox[{
       RowBox[{"1", "/", "2"}], " ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"-", "1"}], "+", 
         RowBox[{"SWSHq", "[", 
          RowBox[{"s", ",", "l", ",", "m"}], "]"}], "-", "s", "-", 
         RowBox[{"Abs", "[", 
          RowBox[{"m", "+", "s"}], "]"}]}], ")"}]}]}], ";", "\n", "  ", 
     RowBox[{"RecRelgen", "=", 
      RowBox[{
       RowBox[{
        RowBox[{"1", "/", "2"}], "  ", 
        RowBox[{"(", 
         RowBox[{"1", "+", "n", "+", "\[Nu]gen", "+", 
          RowBox[{"Abs", "[", 
           RowBox[{"m", "+", "s"}], "]"}]}], ")"}], " ", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"2", 
           RowBox[{"(", 
            RowBox[{"1", "+", "n", "+", "\[Nu]gen", "+", "s"}], ")"}]}], "-", 
          RowBox[{"Abs", "[", 
           RowBox[{"m", "-", "s"}], "]"}], "+", 
          RowBox[{"Abs", "[", 
           RowBox[{"m", "+", "s"}], "]"}]}], ")"}], 
        RowBox[{"AFgen", "[", 
         RowBox[{"n", "+", "1"}], "]"}]}], "+", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"-", "1"}], "-", "m", "-", 
          RowBox[{"m", "^", "2"}], "-", 
          RowBox[{"2", " ", 
           RowBox[{"(", 
            RowBox[{"n", "+", " ", "\[Nu]gen"}], ")"}]}], "+", 
          RowBox[{"4", " ", "c", " ", "n"}], "-", 
          RowBox[{"2", " ", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"n", "+", "\[Nu]gen"}], ")"}], "^", "2"}]}], "-", "s", 
          "-", 
          RowBox[{"m", " ", "s"}], "-", 
          RowBox[{"2", " ", 
           RowBox[{"(", 
            RowBox[{"n", "+", "\[Nu]gen"}], ")"}], " ", "s"}], "-", 
          RowBox[{"4", " ", "c", " ", "Asgen"}], "-", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"1", "+", 
             RowBox[{"2", " ", "n"}], "+", 
             RowBox[{"2", " ", "\[Nu]gen"}], "+", "s"}], ")"}], " ", 
           RowBox[{"Abs", "[", 
            RowBox[{"m", "+", "s"}], "]"}]}]}], ")"}], 
        RowBox[{"AFgen", "[", "n", "]"}]}], " ", "+", " ", 
       RowBox[{
        RowBox[{"1", "/", "2"}], "  ", 
        RowBox[{"(", 
         RowBox[{"n", "+", "\[Nu]gen"}], ")"}], " ", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"2", " ", 
           RowBox[{"(", 
            RowBox[{"n", "+", "\[Nu]gen", "+", "s"}], ")"}]}], "+", 
          RowBox[{"Abs", "[", 
           RowBox[{"m", "-", "s"}], "]"}], "+", 
          RowBox[{"Abs", "[", 
           RowBox[{"m", "+", "s"}], "]"}]}], ")"}], 
        RowBox[{"AFgen", "[", 
         RowBox[{"n", "-", "1"}], "]"}]}]}]}], ";", "\n", "\n", "  ", 
     RowBox[{
      RowBox[{"Serngen", "[", "nn_", "]"}], ":=", 
      RowBox[{
       RowBox[{"Serngen", "[", "nn", "]"}], "=", 
       RowBox[{"Collect", "[", 
        RowBox[{
         RowBox[{"CoefficientList", "[", 
          RowBox[{
           RowBox[{"Normal", "[", 
            RowBox[{"Series", "[", 
             RowBox[{
              RowBox[{"RecRelgen", "/.", 
               RowBox[{"n", "->", "nn"}]}], ",", 
              RowBox[{"{", 
               RowBox[{"c", ",", " ", "\[Infinity]", ",", " ", 
                RowBox[{"order", "+", "1"}]}], "}"}]}], "]"}], "]"}], ",", 
           RowBox[{"c", "^", 
            RowBox[{"-", "1"}]}]}], "]"}], ",", 
         RowBox[{"aFgen", "[", 
          RowBox[{"_", ",", "_"}], "]"}]}], "]"}]}]}], ";", "\n", "\n", "  ", 
     RowBox[{"Do", "[", "\n", "    ", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"\[Delta]gen", "[", "p", "]"}], "=", 
         RowBox[{
          RowBox[{"\[Delta]gen", "[", "p", "]"}], "/.", 
          RowBox[{
           RowBox[{"Solve", "[", 
            RowBox[{
             RowBox[{
              RowBox[{
               RowBox[{"Serngen", "[", "0", "]"}], "[", 
               RowBox[{"[", "p", "]"}], "]"}], "==", "0"}], ",", 
             RowBox[{"\[Delta]gen", "[", "p", "]"}]}], "]"}], "[", 
           RowBox[{"[", "1", "]"}], "]"}]}]}], ";", "\n", "    ", 
        RowBox[{"Do", "[", 
         RowBox[{
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{"k", "!=", "0"}], ",", 
            RowBox[{
             RowBox[{"aFgen", "[", 
              RowBox[{"k", ",", "p"}], "]"}], "=", 
             RowBox[{
              RowBox[{"aFgen", "[", 
               RowBox[{"k", ",", "p"}], "]"}], "/.", 
              RowBox[{
               RowBox[{"Solve", "[", 
                RowBox[{
                 RowBox[{
                  RowBox[{
                   RowBox[{"Serngen", "[", "k", "]"}], "[", 
                   RowBox[{"[", "p", "]"}], "]"}], "==", "0"}], ",", 
                 RowBox[{"aFgen", "[", 
                  RowBox[{"k", ",", "p"}], "]"}]}], "]"}], "[", 
               RowBox[{"[", "1", "]"}], "]"}]}]}]}], "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"k", ",", " ", 
            RowBox[{"-", "p"}], ",", " ", "p"}], "}"}]}], "]"}]}], "\n", "  ",
        ",", 
       RowBox[{"{", 
        RowBox[{"p", ",", " ", "1", ",", " ", 
         RowBox[{"order", "+", "1"}]}], "}"}]}], "]"}], ";", "\n", "  ", "\n",
      "  ", 
     RowBox[{"Asum", " ", "=", " ", 
      RowBox[{"4", "\[Gamma]", " ", 
       RowBox[{"Sum", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"\[Delta]gen", "[", "k", "]"}], 
          RowBox[{"\[Gamma]", "^", 
           RowBox[{"-", "k"}]}]}], ",", 
         RowBox[{"{", 
          RowBox[{"k", ",", " ", "2", ",", " ", 
           RowBox[{"order", "+", "1"}]}], "}"}]}], "]"}]}]}], ";", "\n", "\n",
      "  ", 
     RowBox[{"sElm", " ", "=", " ", 
      RowBox[{
       RowBox[{"-", 
        RowBox[{"\[Gamma]", "^", "2"}]}], "+", " ", 
       RowBox[{"2", " ", 
        RowBox[{"SWSHq", "[", 
         RowBox[{"s", ",", "l", ",", "m"}], "]"}], " ", "\[Gamma]"}], "-", 
       RowBox[{
        RowBox[{"1", "/", "2"}], " ", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{
           RowBox[{"SWSHq", "[", 
            RowBox[{"s", ",", "l", ",", "m"}], "]"}], "^", "2"}], "-", 
          RowBox[{"m", "^", "2"}], "-", 
          RowBox[{"2", 
           RowBox[{"s", "^", "2"}]}], "+", "1"}], ")"}]}], "+", "Asum"}]}], 
     ";", "\n", "\n", "  ", 
     RowBox[{"s\[Lambda]lm", " ", "=", " ", 
      RowBox[{"sElm", "-", 
       RowBox[{"s", 
        RowBox[{"(", 
         RowBox[{"s", "+", "1"}], ")"}]}], "+", 
       RowBox[{"\[Gamma]", "^", "2"}], "-", 
       RowBox[{"2", "m", " ", "\[Gamma]"}]}]}], ";", "\n", "  ", "\n", "  ", 
     RowBox[{"res", " ", "=", " ", 
      RowBox[{"SeriesData", "[", 
       RowBox[{"\[Gamma]", ",", " ", "\[Infinity]", ",", " ", 
        RowBox[{"Reverse", "[", 
         RowBox[{"CoefficientList", "[", 
          RowBox[{
           RowBox[{"Expand", "[", 
            RowBox[{"s\[Lambda]lm", " ", 
             RowBox[{"\[Gamma]", "^", "order"}]}], "]"}], ",", "\[Gamma]"}], 
          "]"}], "]"}], ",", " ", 
        RowBox[{"-", "1"}], ",", " ", 
        RowBox[{"order", "+", "1"}], ",", " ", "1"}], "]"}]}], ";", "\n", 
     "\n", "  ", 
     RowBox[{"Remove", "[", 
      RowBox[{
      "aFgen", ",", " ", "AFgen", ",", " ", "\[Delta]gen", ",", " ", 
       "Serngen", ",", " ", "c", ",", " ", "n"}], "]"}], ";", "\n", "\n", 
     "  ", "res"}]}], "\n", "]"}]}]], "Code",
 CellLabel->"In[45]:=",ExpressionUUID->"8dd82234-67c1-433d-98da-d296531c3029"]
}, Open  ]],

