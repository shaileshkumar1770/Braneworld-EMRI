       ",", "dRup", ",", "swshpar", ",", "\[ScriptCapitalA]0", ",", 
      "\[ScriptCapitalA]1", ",", "\[ScriptCapitalA]2", ",", 
      "\[ScriptCapitalA]3", ",", "\n", "rpK", ",", "rmK", ",", "rp", ",", 
      "rm", ",", "E0", ",", "Lz", ",", 
      RowBox[{"q", "=", "0"}], ",", 
      RowBox[{"\[Chi]", "=", "0"}], ",", 
      RowBox[{"a", "=", "0"}], ",", "AbsCSq", ",", "\[Kappa]", ",", 
      "\[Epsilon]", ",", "\[Alpha]lmk", ",", "Flux\[Infinity]", ",", "FluxH", 
      ",", "ZHZIdata"}], "}"}], ",", "\n", 
    RowBox[{
     RowBox[{"ZHZIdata", "=", 
      RowBox[{"ZISwm", "[", 
       RowBox[{
       "p", ",", "e", ",", "l", ",", "m", ",", "n", ",", "Q", ",", 
        "\[Delta]"}], "]"}]}], ";", "\n", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"ZH", ",", "Z\[Infinity]"}], "}"}], "=", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"ZHZIdata", "[", "\"\<ampZH\>\"", "]"}], ",", 
        RowBox[{"ZHZIdata", "[", "\"\<ampZ\[Infinity]\>\"", "]"}]}], "}"}]}], 
     ";", "\n", 
     RowBox[{"rHout", "=", 
      RowBox[{"ZHZIdata", "[", "\"\<rHout\>\"", "]"}]}], ";", "\n", 
     RowBox[{"\[CapitalOmega]", "=", 
      RowBox[{"ZHZIdata", "[", "\"\<\[CapitalOmega]\>\"", "]"}]}], ";", "\n", 
