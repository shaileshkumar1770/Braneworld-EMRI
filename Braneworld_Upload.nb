              RowBox[{"norm", " ", "+=", " ", 
               RowBox[{"normterm", "[", "nmax", "]"}]}], ")"}]}], ",", " ", 
            RowBox[{"nmax", "++"}]}], "]"}], ";"}], ",", "\n", "   ", 
         "_Integer", ",", "\n", "    ", 
         RowBox[{
          RowBox[{"nmax", " ", "=", " ", 
           RowBox[{
            RowBox[{"OptionValue", "[", "\"\<NumTerms\>\"", "]"}], " ", "-", 
