            RowBox[{"Gamma", "[", 
             RowBox[{"1", "+", 
              RowBox[{"2", " ", "k2"}]}], "]"}], " ", "norm"}], ")"}], "^", 
          RowBox[{"(", 
           RowBox[{"1", "/", "2"}], ")"}]}]}]}], ";", "\n", "  ", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Precision", "[", "norm", "]"}], " ", "==", " ", "0."}], 
