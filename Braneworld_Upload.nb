 CellLabel->"In[68]:=",ExpressionUUID->"7af1ea42-8498-4eed-a9b2-c827d1557025"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"SpinWeightedSphericalHarmonicY", "[", 
     RowBox[{
     "s_Integer", ",", " ", "l_Integer", ",", " ", "m_Integer", ",", " ", 
      "\[Theta]_", ",", " ", "\[Phi]_"}], "]"}], " ", ":=", "\n", "  ", 
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{"-", "1"}], ")"}], "^", "m"}], " ", 
     RowBox[{"Sqrt", "[", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{"l", "+", "m"}], ")"}], "!"}], 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"l", "-", "m"}], ")"}], "!"}], 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"2", "l"}], "+", "1"}], ")"}]}], ")"}], "/", 
       RowBox[{"(", 
        RowBox[{"4", "\[Pi]", " ", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"l", "+", "s"}], ")"}], "!"}], 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"l", "-", "s"}], ")"}], "!"}]}], ")"}]}], "]"}], " ", 
     RowBox[{"Sum", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Binomial", "[", 
         RowBox[{
          RowBox[{"l", "-", "s"}], ",", "r"}], "]"}], " ", 
        RowBox[{"Binomial", "[", 
         RowBox[{
          RowBox[{"l", "+", "s"}], ",", 
          RowBox[{"r", "+", "s", "-", "m"}]}], "]"}], " ", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"-", "1"}], ")"}], "^", 
         RowBox[{"(", 
          RowBox[{"l", "-", "r", "-", "s"}], ")"}]}], " ", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"(", 
            RowBox[{
             RowBox[{"2", " ", "l"}], " ", "-", " ", 
             RowBox[{"2", " ", "r"}], " ", "-", " ", "s", " ", "+", " ", 
             "m"}], ")"}], "==", "0"}], ",", " ", "1", ",", " ", 
          RowBox[{
           RowBox[{"Sin", "[", 
            RowBox[{"\[Theta]", "/", "2"}], "]"}], "^", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"2", " ", "l"}], " ", "-", " ", 
             RowBox[{"2", " ", "r"}], " ", "-", " ", "s", " ", "+", " ", 
             "m"}], ")"}]}]}], "]"}], " ", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"(", 
            RowBox[{
             RowBox[{"2", " ", "r"}], " ", "+", " ", "s", " ", "-", " ", 
             "m"}], ")"}], "==", "0"}], ",", " ", "1", ",", " ", 
          RowBox[{
           RowBox[{"Cos", "[", 
            RowBox[{"\[Theta]", "/", "2"}], "]"}], "^", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"2", " ", "r"}], " ", "+", " ", "s", " ", "-", " ", 
             "m"}], ")"}]}]}], "]"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"r", ",", 
         RowBox[{"Max", "[", 
          RowBox[{
           RowBox[{"m", "-", "s"}], ",", "0"}], "]"}], ",", 
         RowBox[{"Min", "[", 
          RowBox[{
           RowBox[{"l", "-", "s"}], ",", 
           RowBox[{"l", "+", "m"}]}], "]"}]}], "}"}]}], "]"}], 
     RowBox[{"Exp", "[", 
      RowBox[{"I", " ", "m", " ", "\[Phi]"}], "]"}]}]}], ";"}], 
  "\n"}]], "Code",
 CellLabel->"In[69]:=",ExpressionUUID->"deaa6755-face-4fa6-ab91-de5f631fe64a"],

