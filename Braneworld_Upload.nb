           RowBox[{"2", "+", "l", "+", "s"}], ")"}]}], ")"}], "/", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"1", "+", 
            RowBox[{"2", " ", "l"}]}], ")"}], " ", 
          RowBox[{"(", 
           RowBox[{"5", "+", 
            RowBox[{"2", " ", "l"}]}], ")"}]}], ")"}]}], "]"}], " ", 
      RowBox[{"\[Gamma]", "^", "2"}]}], ")"}], "/", 
    RowBox[{"(", 
