Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"SWSHEigenvalueLeaver", "[", 
    RowBox[{
    "s_", ",", " ", "l_", ",", " ", "m_", ",", " ", "\[Gamma]_", ",", " ", 
     RowBox[{"opts", ":", 
      RowBox[{"OptionsPattern", "[", "]"}]}]}], "]"}], " ", ":=", "\n", " ", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "Myprec", ",", " ", "Nmax", ",", " ", "nInv", ",", " ", "\[Alpha]", ",",
        " ", "\[Beta]", ",", " ", "\[Alpha]n", ",", " ", "\[Beta]n", ",", " ",
        "\[Gamma]n", ",", " ", "n", ",", " ", "LHS", ",", " ", "RHS", ",", 
       " ", "Eq", ",", " ", "A", ",", " ", "Aval", ",", " ", "Avar", ",", " ",
        "Aini"}], "}"}], ",", "\n", "  ", 
     RowBox[{
      RowBox[{"Aini", " ", "=", " ", 
       RowBox[{"OptionValue", "[", "\"\<InitialGuess\>\"", "]"}]}], ";", "\n",
       "  ", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"Aini", " ", "===", " ", "\"\<SphericalExpansion\>\""}], ",", 
        "\n", "    ", 
        RowBox[{
         RowBox[{"Aini", " ", "=", " ", 
          RowBox[{"Quiet", "[", 
           RowBox[{
            RowBox[{"SetPrecision", "[", 
             RowBox[{
              RowBox[{"SWSHEigenvalueSpectral", "[", 
               RowBox[{"s", ",", " ", "l", ",", " ", "m", ",", " ", 
                RowBox[{"N", "[", "\[Gamma]", "]"}]}], "]"}], ",", " ", 
              RowBox[{"Precision", "[", "\[Gamma]", "]"}]}], "]"}], ",", " ", 
            RowBox[{"SpinWeightedSpheroidalEigenvalue", "::", "numterms"}]}], 
           "]"}]}], ";"}]}], "\n", "  ", "]"}], ";", "\n", "  ", 
      RowBox[{"Switch", "[", 
       RowBox[{
        RowBox[{"OptionValue", "[", "\"\<NumInversions\>\"", "]"}], ",", "\n",
         "   ", "Automatic", ",", "\n", "    ", 
        RowBox[{
         RowBox[{"nInv", " ", "=", " ", 
          RowBox[{"l", "-", 
           RowBox[{"Max", "[", 
            RowBox[{
             RowBox[{"Abs", "[", "m", "]"}], ",", 
             RowBox[{"Abs", "[", "s", "]"}]}], "]"}]}]}], ";"}], ",", "\n", 
        "   ", "_Integer", ",", "\n", "    ", 
        RowBox[{
         RowBox[{"nInv", " ", "=", " ", 
          RowBox[{"OptionValue", "[", "\"\<NumInversions\>\"", "]"}]}], ";"}],
         ",", "\n", "   ", "_", ",", "\n", "    ", 
        RowBox[{
         RowBox[{"Message", "[", 
          RowBox[{
           RowBox[{"SpinWeightedSpheroidalEigenvalue", "::", "optx"}], ",", 
           " ", 
           RowBox[{"Method", " ", "->", " ", 
            RowBox[{"{", 
             RowBox[{"\"\<Leaver\>\"", ",", " ", "opts"}], "}"}]}]}], "]"}], 
         ";", "\n", "    ", 
         RowBox[{"Return", "[", "$Failed", "]"}], ";"}]}], "\n", "  ", "]"}], 
      ";", "\n", "  ", 
      RowBox[{"Myprec", " ", "=", " ", 
       RowBox[{"Max", "[", 
        RowBox[{
         RowBox[{"Precision", "[", "\[Gamma]", "]"}], ",", " ", "3"}], 
        "]"}]}], ";", "\n", "  ", 
      RowBox[{"\[Alpha]", " ", "=", " ", 
       RowBox[{"Abs", "[", 
        RowBox[{"m", "+", "s"}], "]"}]}], ";", "\n", "  ", 
      RowBox[{"\[Beta]", " ", "=", " ", 
       RowBox[{"Abs", "[", 
        RowBox[{"m", "-", "s"}], "]"}]}], ";", "\n", "  ", 
      RowBox[{
       RowBox[{"\[Alpha]n", "[", "n_", "]"}], " ", ":=", " ", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"-", "4"}], "\[Gamma]", 
          RowBox[{"(", 
           RowBox[{"n", "+", "\[Alpha]", "+", "1"}], ")"}], 
          RowBox[{"(", 
           RowBox[{"n", "+", "\[Beta]", "+", "1"}], ")"}], 
          RowBox[{"(", 
           RowBox[{"n", "+", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{"\[Alpha]", "+", "\[Beta]"}], ")"}], "/", "2"}], "+", 
            "1", "+", "s"}], " ", ")"}]}], ")"}], "/", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"2", "n"}], "+", "\[Alpha]", "+", "\[Beta]", "+", "2"}], 
           ")"}], 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"2", "n"}], "+", "\[Alpha]", "+", "\[Beta]", "+", "3"}], 
           ")"}]}], ")"}]}]}], ";", "\n", "  ", 
      RowBox[{
       RowBox[{"\[Beta]n", "[", 
        RowBox[{"n_", ",", " ", "A_"}], "]"}], " ", ":=", " ", 
       RowBox[{"A", " ", "+", " ", 
        RowBox[{"s", 
         RowBox[{"(", 
          RowBox[{"s", "+", "1"}], ")"}]}], "+", 
        RowBox[{"\[Gamma]", "^", "2"}], " ", "-", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"n", " ", "+", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"\[Alpha]", "+", "\[Beta]"}], ")"}], "/", "2"}]}], ")"}], 
         RowBox[{"(", 
          RowBox[{"n", " ", "+", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"\[Alpha]", "+", "\[Beta]"}], ")"}], "/", "2"}], "+", 
           "1"}], ")"}]}], " ", "+", " ", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"s", "!=", "0"}], ",", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"8", "m", " ", 
             RowBox[{"s", "^", "2"}], " ", "\[Gamma]"}], ")"}], "/", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{
               RowBox[{"2", "n"}], "+", "\[Alpha]", "+", "\[Beta]"}], ")"}], 
             RowBox[{"(", 
              RowBox[{
               RowBox[{"2", "n"}], "+", "\[Alpha]", "+", "\[Beta]", "+", 
               "2"}], ")"}]}], ")"}]}], ",", "0"}], "]"}]}]}], ";", "\n", 
      "  ", 
      RowBox[{
       RowBox[{"\[Gamma]n", "[", "n_", "]"}], " ", ":=", " ", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"4", "\[Gamma]", " ", "n", 
          RowBox[{"(", 
           RowBox[{"n", "+", "\[Alpha]", "+", "\[Beta]"}], ")"}], 
          RowBox[{"(", 
           RowBox[{"n", "+", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{"\[Alpha]", "+", "\[Beta]"}], ")"}], "/", "2"}], "-", 
            "s"}], ")"}]}], ")"}], "/", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"2", "n"}], "+", "\[Alpha]", "+", "\[Beta]", "-", "1"}], 
           ")"}], 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"2", "n"}], "+", "\[Alpha]", "+", "\[Beta]"}], ")"}]}], 
         ")"}]}]}], ";", "\n", "  ", 
      RowBox[{
       RowBox[{"RHS", "[", "Ax_", "]"}], " ", ":=", " ", 
       RowBox[{"-", 
        RowBox[{"CF", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"-", 
            RowBox[{"\[Alpha]n", "[", 
             RowBox[{"n", "-", "1"}], "]"}]}], " ", 
           RowBox[{"\[Gamma]n", "[", "n", "]"}]}], ",", " ", 
          RowBox[{"\[Beta]n", "[", 
           RowBox[{"n", ",", "Ax"}], "]"}], ",", " ", 
          RowBox[{"{", 
           RowBox[{"n", ",", " ", 
            RowBox[{"nInv", "+", "1"}]}], "}"}]}], "]"}]}]}], ";", "\n", "  ", 
      RowBox[{
       RowBox[{"LHS", "[", "Ax_", "]"}], " ", ":=", " ", 
       RowBox[{
        RowBox[{"\[Beta]n", "[", 
         RowBox[{"nInv", ",", " ", "Ax"}], "]"}], " ", "+", " ", 
        RowBox[{"ContinuedFractionK", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"-", 
            RowBox[{"\[Alpha]n", "[", 
             RowBox[{"nInv", "-", "n"}], "]"}]}], " ", 
           RowBox[{"\[Gamma]n", "[", 
            RowBox[{"nInv", "-", "n", "+", "1"}], "]"}]}], ",", " ", 
          RowBox[{"\[Beta]n", "[", 
           RowBox[{
            RowBox[{"nInv", "-", "n"}], ",", " ", "Ax"}], "]"}], ",", " ", 
          RowBox[{"{", 
           RowBox[{"n", ",", " ", "1", ",", " ", "nInv"}], "}"}]}], "]"}]}]}],
       ";", "\n", "  ", 
      RowBox[{
       RowBox[{"Eq", "[", 
        RowBox[{"A_", "?", "NumericQ"}], "]"}], " ", ":=", " ", 
       RowBox[{
        RowBox[{"LHS", "[", "A", "]"}], " ", "-", " ", 
        RowBox[{"RHS", "[", "A", "]"}]}]}], ";", "\n", "  ", 
      RowBox[{"Aval", " ", "=", " ", 
       RowBox[{"Avar", " ", "/.", " ", 
        RowBox[{"Quiet", "[", 
         RowBox[{
          RowBox[{"Check", "[", 
           RowBox[{
            RowBox[{"FindRoot", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"Eq", "[", "Avar", "]"}], "==", "0"}], ",", " ", 
              RowBox[{"{", 
               RowBox[{"Avar", ",", " ", "Aini"}], "}"}], ",", " ", 
              RowBox[{"AccuracyGoal", " ", "->", " ", 
               RowBox[{"Myprec", "-", "3"}]}], ",", " ", 
              RowBox[{"WorkingPrecision", " ", "->", " ", "Myprec"}], ",", 
              " ", 
              RowBox[{"Method", " ", "->", " ", "\"\<Secant\>\""}]}], "]"}], 
            ",", " ", 
            RowBox[{"Avar", " ", "->", " ", "$Failed"}], ",", " ", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"Power", "::", "infy"}], ",", " ", 
              RowBox[{"FindRoot", "::", "nlnum"}]}], "}"}]}], "]"}], ",", " ", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"Power", "::", "infy"}], ",", " ", 
            RowBox[{"FindRoot", "::", "nlnum"}]}], "}"}]}], "]"}]}]}], ";", 
      "\n", "  ", 
      RowBox[{"Clear", "[", 
       RowBox[{
       "\[Alpha]n", ",", " ", "\[Beta]n", ",", " ", "\[Gamma]n", ",", " ", 
        "LHS", ",", " ", "RHS", ",", " ", "Eq"}], "]"}], ";", "\n", "  ", 
      "Aval"}]}], "\n", "]"}]}], ";"}]], "Code",
 CellLabel->"In[34]:=",ExpressionUUID->"d7d1c217-1860-46ff-b8b4-256b71e2889b"]
