Cell[BoxData[
 RowBox[{
  RowBox[{"ZISwm", "[", 
   RowBox[{
   "p_", ",", "e_", ",", "l_", ",", "m_", ",", "n_", ",", "Q_", ",", 
    "\[Delta]_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "rHout", ",", "\[CapitalOmega]", ",", "\[CapitalLambda]", ",", 
      "\[CapitalDelta]", ",", "kT", ",", "VT", ",", "dVT", ",", "dlm\[Omega]",
       ",", "c0", ",", "\[ScriptCapitalD]trans", ",", "Bin", ",", 
      "\[ScriptCapitalI]H", ",", "\[ScriptCapitalI]\[Infinity]", ",", "ZH", 
      ",", "Z\[Infinity]", ",", "Rin", ",", "dRin", ",", "Rup", ",", "dRup", 
      ",", "swshpar", ",", "\[ScriptCapitalA]0", ",", "\[ScriptCapitalA]1", 
      ",", "\[ScriptCapitalA]2", ",", "\[ScriptCapitalA]3", ",", "rpK", ",", 
      "\n", "rmK", ",", "rp", ",", "rm", ",", "E0", ",", "Lz", ",", 
      "\[CapitalOmega]r", ",", "\[CapitalOmega]\[Phi]", ",", "swsh", ",", 
      "fsimpson", ",", "ZHAmp", ",", "Z\[Infinity]Amp", ",", "ampComp", ",", 
      "xa", ",", "xb", ",", "hstep", ",", "nS", ",", "xlist"}], "}"}], ",", 
    "\n", 
    RowBox[{
     RowBox[{
      RowBox[{"{", 
       RowBox[{"rp", ",", "rm"}], "}"}], "=", 
      RowBox[{"rprm", "[", "Q", "]"}]}], ";", "\n", 
     RowBox[{"rHout", "=", "rp"}], ";", "\n", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"\[CapitalOmega]r", ",", "\[CapitalOmega]\[Phi]"}], "}"}], "=", 
      RowBox[{"Frequencies", "[", 
       RowBox[{"a", ",", "p", ",", "e", ",", "Q"}], "]"}]}], ";", "\n", 
     RowBox[{"\[CapitalOmega]", "=", 
      RowBox[{
       RowBox[{"m", " ", "\[CapitalOmega]\[Phi]"}], "+", " ", 
       RowBox[{"n", " ", "\[CapitalOmega]r"}]}]}], ";", "\n", 
     RowBox[{"swshpar", "=", 
      RowBox[{"angpar", "[", 
       RowBox[{"\[CapitalOmega]", ",", "l", ",", "m"}], "]"}]}], ";", "\n", 
     RowBox[{"\[CapitalLambda]", "=", 
      RowBox[{"swshpar", "[", 
       RowBox[{"[", "1", "]"}], "]"}]}], ";", "\n", 
     RowBox[{
      RowBox[{"ampComp", "[", "\[Chi]_", "]"}], ":=", 
      RowBox[{"Block", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"EnLzdata", ",", "r0"}], "}"}], ",", "\n", 
        RowBox[{
         RowBox[{"r0", "=", 
          RowBox[{"p", "/", 
           RowBox[{"(", 
            RowBox[{"1", "+", 
             RowBox[{"e", " ", 
              RowBox[{"Cos", "[", "\[Chi]", "]"}]}]}], ")"}]}]}], ";", "\n", 
         RowBox[{"\[CapitalDelta]", "=", 
          RowBox[{
           RowBox[{"r0", "^", "2"}], "-", 
           RowBox[{"2", " ", "M", " ", "r0"}], "+", " ", "Q"}]}], ";", "\n", 
         RowBox[{"kT", "=", 
          RowBox[{
           RowBox[{
            RowBox[{"(", 
             RowBox[{"#", "^", "2"}], ")"}], "\[CapitalOmega]"}], "&"}]}], 
         ";", "\n", 
         RowBox[{"VT", "=", 
          RowBox[{
           RowBox[{"Evaluate", "[", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"-", 
               RowBox[{"(", 
                RowBox[{
                 RowBox[{"(", 
                  RowBox[{
                   RowBox[{
                    RowBox[{"kT", "[", "#", "]"}], "^", "2"}], "+", 
                   RowBox[{"4", "I", " ", 
                    RowBox[{"(", 
                    RowBox[{"#", "-", "M"}], ")"}], 
                    RowBox[{"kT", "[", "#", "]"}]}]}], ")"}], "/", 
                 RowBox[{"(", 
                  RowBox[{
                   RowBox[{"#", "^", "2"}], "-", 
                   RowBox[{"2", " ", "M", " ", "#"}]}], " ", ")"}]}], ")"}]}],
               "+", 
              RowBox[{"8", "I", " ", "\[CapitalOmega]", " ", "#"}], "+", 
              "\[CapitalLambda]", "+", 
              RowBox[{"\[Delta]", " ", 
               RowBox[{"(", 
                RowBox[{"-", 
                 FractionBox[
                  RowBox[{"2", "Q"}], 
                  SuperscriptBox["#", "2"]]}], ")"}]}]}], ")"}], "]"}], 
           "&"}]}], ";", "\n", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"Rin", ",", "dRin", ",", "Rup", ",", "dRup", ",", "Bin"}], 
           "}"}], "=", 
          RowBox[{"TeukolskyInUp", "[", 
           RowBox[{
           "r0", ",", "\[CapitalOmega]", ",", "m", ",", "\[CapitalLambda]", 
            ",", "Q", ",", "\[Delta]"}], "]"}]}], ";", "\n", 
         RowBox[{"EnLzdata", "=", 
          RowBox[{"KerrGeoConstantsOfMotionN", "[", 
           RowBox[{"a", ",", " ", "p", ",", " ", "e", ",", " ", "Q"}], 
           "]"}]}], ";", "\n", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"E0", ",", "Lz"}], "}"}], "=", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"EnLzdata", "[", "\"\<\[ScriptCapitalE]\>\"", "]"}], ",", 
            RowBox[{"EnLzdata", "[", "\"\<\[ScriptCapitalL]\>\"", "]"}]}], 
           "}"}]}], ";", "\n", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
           "\[ScriptCapitalA]0", ",", "\[ScriptCapitalA]1", ",", 
            "\[ScriptCapitalA]2", ",", "swsh"}], "}"}], "=", 
          RowBox[{"sourceterm", "[", 
           RowBox[{"r0", ",", "\[CapitalOmega]", ",", "m", ",", "Q", ",", 
            RowBox[{"swshpar", "[", 
             RowBox[{"[", 
              RowBox[{"2", ";;", "4"}], "]"}], "]"}], ",", "E0", ",", "Lz"}], 
           "]"}]}], ";", "\n", "\n", 
         RowBox[{"\[ScriptCapitalI]H", "=", 
          RowBox[{
           RowBox[{
            RowBox[{"(", 
             RowBox[{"\[ScriptCapitalA]0", "+", 
              RowBox[{"\[ScriptCapitalA]2", " ", 
               RowBox[{
                RowBox[{"VT", "[", "r0", "]"}], "/", "\[CapitalDelta]"}]}]}], 
             ")"}], "Rin"}], "+", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{
              RowBox[{"-", "\[ScriptCapitalA]1"}], "+", 
              RowBox[{
               RowBox[{
                RowBox[{"(", 
                 RowBox[{"2", 
                  RowBox[{"(", 
