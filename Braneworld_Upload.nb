Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"kHat", "[", 
    RowBox[{"s_", ",", " ", "0", ",", " ", "0", ",", " ", "\[Gamma]_"}], 
    "]"}], " ", ":=", " ", 
   RowBox[{
    RowBox[{"\[Gamma]", "^", "2"}], "/", "3"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"kHat", "[", 
    RowBox[{"s_", ",", " ", "l_", ",", " ", "m_", ",", " ", "\[Gamma]_"}], 
    "]"}], " ", ":=", " ", 
   RowBox[{
    RowBox[{
     RowBox[{"-", "l"}], " ", 
     RowBox[{"(", 
      RowBox[{"1", "+", "l"}], ")"}]}], "+", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"2", " ", "m", " ", 
       RowBox[{"s", "^", "2"}], " ", "\[Gamma]"}], ")"}], "/", 
     RowBox[{"(", 
      RowBox[{"l", "+", 
       RowBox[{"l", "^", "2"}]}], ")"}]}], "+", 
    RowBox[{
     RowBox[{"1", "/", "3"}], " ", 
     RowBox[{"(", 
      RowBox[{"1", "+", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"2", " ", 
          RowBox[{"(", 
           RowBox[{"l", "+", 
            RowBox[{"l", "^", "2"}], "-", 
            RowBox[{"3", " ", 
             RowBox[{"m", "^", "2"}]}]}], ")"}], " ", 
          RowBox[{"(", 
           RowBox[{"l", "+", 
            RowBox[{"l", "^", "2"}], "-", 
            RowBox[{"3", " ", 
             RowBox[{"s", "^", "2"}]}]}], ")"}]}], ")"}], "/", 
        RowBox[{"(", 
         RowBox[{"l", " ", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"-", "3"}], "+", "l", "+", 
            RowBox[{"8", " ", 
             RowBox[{"l", "^", "2"}]}], "+", 
            RowBox[{"4", " ", 
             RowBox[{"l", "^", "3"}]}]}], ")"}]}], ")"}]}]}], ")"}], " ", 
     RowBox[{"\[Gamma]", "^", "2"}]}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"k2", "[", 
    RowBox[{"s_", ",", " ", "l_", ",", " ", "m_", ",", " ", "\[Gamma]_"}], 
    "]"}], " ", ":=", " ", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"Sqrt", "[", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"1", "+", "l", "-", "m"}], ")"}], " ", 
          RowBox[{"(", 
           RowBox[{"2", "+", "l", "-", "m"}], ")"}], " ", 
          RowBox[{"(", 
           RowBox[{"1", "+", "l", "+", "m"}], ")"}], " ", 
          RowBox[{"(", 
           RowBox[{"2", "+", "l", "+", "m"}], ")"}], " ", 
          RowBox[{"(", 
           RowBox[{"1", "+", "l", "-", "s"}], ")"}], " ", 
          RowBox[{"(", 
