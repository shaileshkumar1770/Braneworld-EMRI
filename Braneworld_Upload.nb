       RowBox[{"\[Lambda]", " ", "=", " ", 
        RowBox[{"SpinWeightedSpheroidalEigenvalue", "[", 
         RowBox[{"s", ",", " ", "l", ",", " ", "m", ",", " ", "\[Gamma]"}], 
         "]"}]}], ";", "\n", "\n", "  ", 
       RowBox[{"(*", " ", 
        RowBox[{
