Cell[CellGroupData[{

Cell["ISCO", "Subsection",ExpressionUUID->"db74d381-5f93-4805-88fd-2091d6963363"],

Cell[BoxData[
 RowBox[{
  RowBox[{"ISCOparV", "[", 
   RowBox[{"a1_", ",", "Q_", ",", 
    RowBox[{"orbit_", "?", "StringQ"}]}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"r", ",", "a", ",", "\[CapitalDelta]", ",", 
      RowBox[{"\[Chi]", "=", "0"}], ",", 
      RowBox[{"q", "=", 
       RowBox[{"10", "^", 
        RowBox[{"-", "5"}]}]}], ",", "\[Alpha]s", ",", "\[Beta]s", ",", 
      "\[Gamma]s", ",", "Veff", ",", "dVeff", ",", "ddVeff", ",", "rp", ",", 
      "rm"}], "}"}], ",", "\n", 
    RowBox[{
     RowBox[{"Which", "[", 
      RowBox[{
       RowBox[{"orbit", "==", "\"\<pro\>\""}], ",", "\n", 
       RowBox[{"a", "=", "a1"}], "\n", ",", "\n", 
       RowBox[{"orbit", "==", "\"\<ret\>\""}], "\n", ",", "\n", 
       RowBox[{"a", "=", 
        RowBox[{"-", "a1"}]}]}], "\n", "]"}], ";", "\n", 
     RowBox[{"\[CapitalDelta]", " ", "=", " ", 
      RowBox[{
       RowBox[{"r", "^", "2"}], " ", "-", " ", 
       RowBox[{"2", " ", "M", " ", "r"}], " ", "+", " ", "Q"}]}], ";", "\n", 
     "\n", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"a", "==", "0"}], ",", "\n", 
       RowBox[{"Block", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"u", ",", "energy", ",", "angmom"}], "}"}], ",", "\n", 
         RowBox[{
          RowBox[{"\[Alpha]s", "=", 
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{"(", 
               RowBox[{
                RowBox[{"r", "^", "2"}], "+", 
                RowBox[{"a", "^", "2"}], "+", 
                RowBox[{
                 RowBox[{"(", 
                  RowBox[{"a", " ", "q", " ", "\[Chi]", " ", "M", 
                   RowBox[{"(", 
                    RowBox[{"r", "+", "M"}], ")"}]}], ")"}], "/", " ", 
                 "r"}]}], ")"}], "^", "2"}], "-", 
             RowBox[{"\[CapitalDelta]", " ", 
              RowBox[{
               RowBox[{"(", 
                RowBox[{"a", "+", 
                 RowBox[{"q", " ", "\[Chi]", " ", "M"}]}], ")"}], "^", 
               "2"}]}]}], "/.", 
            RowBox[{"r", "->", 
             RowBox[{"u", "^", 
              RowBox[{"-", "1"}]}]}]}]}], ";", "\n", 
          RowBox[{"\[Beta]s", "=", 
           RowBox[{
            RowBox[{
             RowBox[{"(", 
              RowBox[{
               RowBox[{
                RowBox[{"(", 
                 RowBox[{"a", "+", " ", 
                  RowBox[{
                   RowBox[{"(", 
                    RowBox[{
                    RowBox[{"(", 
                    RowBox[{"M", "^", "2"}], ")"}], " ", "q", " ", "\[Chi]"}],
                     " ", ")"}], "/", " ", "r"}]}], ")"}], 
                RowBox[{"(", 
                 RowBox[{
                  RowBox[{"r", "^", "2"}], "+", 
                  RowBox[{"a", "^", "2"}], "+", " ", 
                  RowBox[{
                   RowBox[{"(", " ", 
                    RowBox[{"a", " ", "q", " ", "\[Chi]", " ", "M", " ", 
                    RowBox[{"(", 
                    RowBox[{"r", "+", "M"}], ")"}]}], ")"}], "/", " ", 
                   "r"}]}], ")"}]}], "-", 
               RowBox[{"\[CapitalDelta]", 
                RowBox[{"(", 
                 RowBox[{"a", "+", 
                  RowBox[{"q", " ", "\[Chi]", " ", "M"}]}], ")"}]}]}], ")"}], 
             "angmom"}], "/.", 
            RowBox[{"r", "->", 
             RowBox[{"u", "^", 
              RowBox[{"-", "1"}]}]}]}]}], ";", "\n", 
          RowBox[{"\[Gamma]s", "=", 
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{
               RowBox[{"(", 
                RowBox[{"a", "+", 
                 RowBox[{
                  RowBox[{"(", 
                   RowBox[{
                    RowBox[{"M", "^", "2"}], " ", "q", " ", "\[Chi]"}], ")"}],
                   "/", " ", "r"}]}], ")"}], "^", "2"}], " ", 
              RowBox[{"angmom", "^", "2"}]}], "-", 
             RowBox[{"\[CapitalDelta]", 
              RowBox[{"(", 
               RowBox[{
                RowBox[{
                 RowBox[{"r", "^", "2"}], " ", 
                 RowBox[{
                  RowBox[{"(", 
                   RowBox[{"1", "-", 
                    RowBox[{
                    RowBox[{"(", 
                    RowBox[{
                    RowBox[{"M", " ", "^", "3"}], " ", 
                    RowBox[{
                    RowBox[{"(", 
                    RowBox[{"q", " ", "\[Chi]"}], " ", ")"}], "^", "2"}]}], 
                    ")"}], "/", 
                    RowBox[{"r", "^", "3"}]}]}], ")"}], "^", "2"}]}], "+", 
                RowBox[{"angmom", "^", "2"}]}], ")"}]}]}], "/.", 
            RowBox[{"r", "->", 
             RowBox[{"u", "^", 
              RowBox[{"-", "1"}]}]}]}]}], ";", "\n", "\n", 
          RowBox[{"Veff", "=", 
           RowBox[{"N", "[", 
            RowBox[{
             RowBox[{"Simplify", "[", 
              RowBox[{
               RowBox[{"u", "^", "4"}], " ", 
               RowBox[{"(", 
                RowBox[{
                 RowBox[{"\[Alpha]s", " ", 
                  RowBox[{"energy", "^", "2"}]}], "-", 
                 RowBox[{"2", "\[Beta]s", " ", "energy"}], "+", "\[Gamma]s"}],
                 ")"}]}], "]"}], ",", "90"}], "]"}]}], ";", "\n", 
          RowBox[{"dVeff", "=", 
           RowBox[{"N", "[", 
            RowBox[{
             RowBox[{"Simplify", "[", 
              RowBox[{"D", "[", 
               RowBox[{"Veff", ",", "u"}], "]"}], "]"}], ",", "90"}], "]"}]}],
           ";", "\n", 
          RowBox[{"ddVeff", "=", 
           RowBox[{"N", "[", 
            RowBox[{
             RowBox[{"Simplify", "[", 
              RowBox[{"D", "[", 
               RowBox[{"Veff", ",", 
                RowBox[{"{", 
                 RowBox[{"u", ",", "2"}], "}"}]}], "]"}], "]"}], ",", "90"}], 
            "]"}]}], ";", "\n", "\n", 
          RowBox[{
           RowBox[{
            RowBox[{"{", 
             RowBox[{
              RowBox[{"u", "^", 
               RowBox[{"-", "1"}]}], ",", "energy", ",", "angmom"}], "}"}], "/.", 
            RowBox[{"First", "@", 
             RowBox[{"Solve", "[", 
              RowBox[{
               RowBox[{
                RowBox[{"Veff", "==", "0"}], "&&", 
                RowBox[{"dVeff", "==", "0"}], "&&", 
                RowBox[{"ddVeff", "==", "0"}], "&&", 
                RowBox[{"energy", ">=", "0"}], "&&", 
                RowBox[{"angmom", ">=", "0"}], "&&", 
                RowBox[{"u", ">", "0"}]}], ",", 
               RowBox[{"{", 
                RowBox[{"u", ",", "energy", ",", "angmom"}], "}"}], ",", 
               "Reals"}], "]"}]}]}], "//", "Quiet"}]}]}], "\n", "]"}], "\n", 
       ",", "\n", 
       RowBox[{"Block", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"u", ",", "energy", ",", "angmom"}], "}"}], ",", "\n", 
         RowBox[{
          RowBox[{"\[Alpha]s", "=", 
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{"(", 
               RowBox[{
                RowBox[{"r", "^", "2"}], "+", 
                RowBox[{"a", "^", "2"}], "+", 
                RowBox[{
                 RowBox[{"(", 
                  RowBox[{"a", " ", "q", " ", "\[Chi]", " ", "M", 
                   RowBox[{"(", 
                    RowBox[{"r", "+", "M"}], ")"}]}], ")"}], "/", " ", 
                 "r"}]}], ")"}], "^", "2"}], "-", 
             RowBox[{"\[CapitalDelta]", " ", 
              RowBox[{
               RowBox[{"(", 
                RowBox[{"a", "+", 
                 RowBox[{"q", " ", "\[Chi]", " ", "M"}]}], ")"}], "^", 
               "2"}]}]}], "/.", 
            RowBox[{"r", "->", 
             RowBox[{"u", "^", 
              RowBox[{"-", "1"}]}]}]}]}], ";", "\n", 
          RowBox[{"\[Beta]s", "=", 
           RowBox[{
            RowBox[{
             RowBox[{"(", 
              RowBox[{
               RowBox[{
                RowBox[{"(", 
                 RowBox[{"a", "+", " ", 
                  RowBox[{
                   RowBox[{"(", 
                    RowBox[{
                    RowBox[{"(", 
                    RowBox[{"M", "^", "2"}], ")"}], " ", "q", " ", "\[Chi]"}],
                     " ", ")"}], "/", " ", "r"}]}], ")"}], 
                RowBox[{"(", 
                 RowBox[{
                  RowBox[{"r", "^", "2"}], "+", 
                  RowBox[{"a", "^", "2"}], "+", " ", 
                  RowBox[{
                   RowBox[{"(", " ", 
                    RowBox[{"a", " ", "q", " ", "\[Chi]", " ", "M", " ", 
                    RowBox[{"(", 
                    RowBox[{"r", "+", "M"}], ")"}]}], ")"}], "/", " ", 
                   "r"}]}], ")"}]}], "-", 
               RowBox[{"\[CapitalDelta]", 
                RowBox[{"(", 
                 RowBox[{"a", "+", 
                  RowBox[{"q", " ", "\[Chi]", " ", "M"}]}], ")"}]}]}], ")"}], 
             "angmom"}], "/.", 
            RowBox[{"r", "->", 
             RowBox[{"u", "^", 
              RowBox[{"-", "1"}]}]}]}]}], ";", "\n", 
          RowBox[{"\[Gamma]s", "=", 
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{
               RowBox[{"(", 
                RowBox[{"a", "+", 
                 RowBox[{
                  RowBox[{"(", 
                   RowBox[{
                    RowBox[{"M", "^", "2"}], " ", "q", " ", "\[Chi]"}], ")"}],
                   "/", " ", "r"}]}], ")"}], "^", "2"}], " ", 
              RowBox[{"angmom", "^", "2"}]}], "-", 
             RowBox[{"\[CapitalDelta]", 
