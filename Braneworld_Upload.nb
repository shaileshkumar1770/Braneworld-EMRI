      "cOutinf"}]}], "\n", "]"}]}], "\n"}]], "Code",
 CellChangeTimes->{{3.9473087899822817`*^9, 3.947308798669017*^9}, {
  3.947310836227435*^9, 3.9473108384906344`*^9}, {3.9474329977089195`*^9, 
  3.947432998049182*^9}},
 CellLabel->"In[99]:=",ExpressionUUID->"a947e30e-c27f-40a9-9eaf-90840e12c19f"]
}, Closed]],

Cell[CellGroupData[{

Cell["\<\
 Homogeneous solutions and amplitude of Teukolsky equation through SN method\
\>", "Section",ExpressionUUID->"fb1dd874-7a65-4bb2-8b51-f718cd6b0737"],

Cell[BoxData[
 RowBox[{
  RowBox[{"homsolSN", "[", 
   RowBox[{
   "r0_", ",", "\[CapitalOmega]_", ",", "m_", ",", "\[Lambda]_", ",", "Q_", 
    ",", "\[Delta]_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "rin", ",", "r\[Infinity]", ",", "rHout", ",", "rHin", ",", 
      "\[CapitalDelta]", ",", "cInH", ",", "cOut\[Infinity]", ",", "bcHor", 
      ",", "bc\[Infinity]", ",", "eqHor", ",", "eqInf", ",", "XHor", ",", 
      "YHor", ",", "X\[Infinity]", ",", "Y\[Infinity]", ",", "r", ",", "X", 
      ",", "Y", ",", "Xin", ",", "dXin", ",", "Xup", ",", "dXup", ",", "rp", 
      ",", "rm"}], "}"}], ",", "\n", 
    RowBox[{
     RowBox[{
      RowBox[{"{", 
       RowBox[{"rp", ",", "rm"}], "}"}], "=", 
      RowBox[{"rprm", "[", "Q", "]"}]}], ";", "\n", 
     RowBox[{"rHout", "=", "rp"}], ";", "\n", 
     RowBox[{"rHin", "=", "rm"}], ";", "\n", "\n", 
     RowBox[{"rin", "=", 
      RowBox[{"rHout", "+", "0.15"}]}], ";", " ", 
     RowBox[{"(*", 
      RowBox[{"Closest", " ", "r", " ", "to", " ", "the", " ", "horizon"}], 
      " ", "*)"}], "\n", 
     RowBox[{"r\[Infinity]", "=", 
      RowBox[{"30", "\[Pi]", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"1", "/", 
          RowBox[{"Abs", "[", "\[CapitalOmega]", "]"}]}], "+", 
         RowBox[{
          RowBox[{"12", "/", "10"}], " ", 
          RowBox[{
           RowBox[{"Abs", "[", "\[CapitalOmega]", "]"}], "/", 
           RowBox[{"(", 
            RowBox[{"1", "+", 
             RowBox[{"Abs", "[", "\[CapitalOmega]", "]"}]}], ")"}]}]}]}], 
        ")"}]}]}], ";", "\n", "\n", 
     RowBox[{"cInH", "=", 
      RowBox[{"BCsHor", "[", 
       RowBox[{
       "\[CapitalOmega]", ",", "m", ",", "\[Lambda]", ",", "Q", ",", 
        "\[Delta]"}], "]"}]}], ";", "\n", 
     RowBox[{"cOut\[Infinity]", "=", 
      RowBox[{"BCs\[Infinity]", "[", 
       RowBox[{
       "\[CapitalOmega]", ",", "m", ",", "\[Lambda]", ",", "Q", ",", 
        "\[Delta]"}], "]"}]}], ";", "\n", "\n", 
     RowBox[{
      RowBox[{"bcHor", "[", "r_", "]"}], ":=", 
      RowBox[{
       RowBox[{"Exp", "[", 
        RowBox[{
         RowBox[{"-", "I"}], 
         RowBox[{"(", "\[CapitalOmega]", ")"}], " ", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{"(", 
              RowBox[{"2", " ", "M", " ", "rHout"}], ")"}], "/", 
             RowBox[{"(", 
              RowBox[{"rHout", "-", "rHin"}], ")"}]}], " ", 
            RowBox[{"Log", "[", 
             RowBox[{"(", 
              RowBox[{"r", "-", "rHout"}], ")"}], "]"}]}], "-", 
           RowBox[{"2", "M", " ", 
            RowBox[{"Log", "[", 
             RowBox[{"2", "M"}], "]"}]}], "-", 
           RowBox[{
            RowBox[{
             RowBox[{"(", 
              RowBox[{"2", " ", "M", " ", "rHin"}], ")"}], "/", 
             RowBox[{"(", 
              RowBox[{"rHout", "-", "rHin"}], ")"}]}], " ", 
            RowBox[{"Log", "[", 
             RowBox[{"(", 
              RowBox[{"rHout", "-", "rHin"}], ")"}], "]"}]}], "+", "rHout"}], 
          ")"}]}], "]"}], 
       RowBox[{"Sum", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"cInH", "[", 
           RowBox[{"[", "i", "]"}], "]"}], 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"r", "-", "rHout"}], ")"}], "^", 
           RowBox[{"(", 
            RowBox[{"i", "-", "1"}], ")"}]}]}], ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", 
           RowBox[{"nmaxHor", "+", "1"}]}], "}"}]}], "]"}]}]}], ";", "\n", 
     "\n", 
     RowBox[{
      RowBox[{"bc\[Infinity]", "[", "r_", "]"}], ":=", 
      RowBox[{
       RowBox[{"Exp", "[", 
        RowBox[{"I", " ", "\[CapitalOmega]", 
         RowBox[{"(", 
          RowBox[{"r", "+", 
           RowBox[{"2", " ", "M", " ", 
            RowBox[{"Log", "[", "r", "]"}]}], "-", 
           RowBox[{"2", "M", " ", 
            RowBox[{"Log", "[", 
             RowBox[{"2", "M"}], "]"}]}]}], ")"}]}], "]"}], 
       RowBox[{"Sum", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"cOut\[Infinity]", "[", 
           RowBox[{"[", "s", "]"}], "]"}], 
          RowBox[{"r", "^", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"-", "s"}], "+", "1"}], ")"}]}]}], ",", 
         RowBox[{"{", 
          RowBox[{"s", ",", 
           RowBox[{"nmax\[Infinity]", "+", "1"}]}], "}"}]}], "]"}]}]}], ";", 
     "\n", "\n", 
     RowBox[{"eqHor", "=", 
      RowBox[{"{", "\n", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"X", "'"}], "[", "r", "]"}], "==", " ", 
         RowBox[{"Y", "[", "r", "]"}]}], ",", "\n", 
        RowBox[{
         RowBox[{
          RowBox[{"Y", "'"}], "[", "r", "]"}], "==", 
         RowBox[{
          RowBox[{
           RowBox[{"-", 
            RowBox[{"pSN", "[", 
             RowBox[{
             "r", ",", "\[CapitalOmega]", ",", "m", ",", "\[Lambda]", ",", 
              "Q", ",", "\[Delta]"}], "]"}]}], 
           RowBox[{"Y", "[", "r", "]"}]}], "-", 
          RowBox[{
           RowBox[{"qSN", "[", 
            RowBox[{
            "r", ",", "\[CapitalOmega]", ",", "m", ",", "\[Lambda]", ",", "Q",
              ",", "\[Delta]"}], "]"}], " ", 
           RowBox[{"X", "[", "r", "]"}]}]}]}], ",", "\n", 
        RowBox[{
         RowBox[{"X", "[", "rin", "]"}], "==", 
         RowBox[{"bcHor", "[", "rin", "]"}]}], ",", 
        RowBox[{
         RowBox[{"Y", "[", "rin", "]"}], "==", " ", 
         RowBox[{
          RowBox[{"bcHor", "'"}], "[", "rin", "]"}]}]}], "\n", "}"}]}], ";", 
     "\n", "\n", 
     RowBox[{"eqInf", "=", 
      RowBox[{"{", "\n", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"X", "'"}], "[", "r", "]"}], "==", " ", 
         RowBox[{"Y", "[", "r", "]"}]}], ",", "\n", 
        RowBox[{
         RowBox[{
          RowBox[{"Y", "'"}], "[", "r", "]"}], "==", 
         RowBox[{
          RowBox[{
           RowBox[{"-", 
            RowBox[{"pSN", "[", 
             RowBox[{
             "r", ",", "\[CapitalOmega]", ",", "m", ",", "\[Lambda]", ",", 
              "Q", ",", "\[Delta]"}], "]"}]}], 
           RowBox[{"Y", "[", "r", "]"}]}], "-", 
          RowBox[{
           RowBox[{"qSN", "[", 
            RowBox[{
            "r", ",", "\[CapitalOmega]", ",", "m", ",", "\[Lambda]", ",", "Q",
              ",", "\[Delta]"}], "]"}], " ", 
           RowBox[{"X", "[", "r", "]"}]}]}]}], ",", "\n", 
        RowBox[{
         RowBox[{"X", "[", "r\[Infinity]", "]"}], "==", 
         RowBox[{"bc\[Infinity]", "[", "r\[Infinity]", "]"}]}], ",", 
        RowBox[{
         RowBox[{"Y", "[", "r\[Infinity]", "]"}], "==", 
         RowBox[{
          RowBox[{"bc\[Infinity]", "'"}], "[", "r\[Infinity]", "]"}]}]}], 
       "\n", "}"}]}], ";", "  ", "\n", "\n", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"XHor", ",", "YHor"}], "}"}], "=", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"X", ",", "Y"}], "}"}], "/.", 
       RowBox[{"First", "@", 
        RowBox[{"NDSolve", "[", 
         RowBox[{"eqHor", ",", 
          RowBox[{"{", 
           RowBox[{"X", ",", "Y"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"r", ",", "rin", ",", "r0"}], "}"}], ",", 
          RowBox[{"Method", "->", "\"\<StiffnessSwitching\>\""}]}], 
         "]"}]}]}]}], ";", "\n", "\n", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"X\[Infinity]", ",", "Y\[Infinity]"}], "}"}], "=", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"X", ",", "Y"}], "}"}], "/.", 
       RowBox[{"First", "@", 
        RowBox[{"NDSolve", "[", 
         RowBox[{"eqInf", ",", 
          RowBox[{"{", 
           RowBox[{"X", ",", "Y"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"r", ",", "rin", ",", "r0"}], "}"}], ",", 
          RowBox[{"Method", "->", "\"\<StiffnessSwitching\>\""}]}], 
         "]"}]}]}]}], ";", "\n", "\n", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"Xin", ",", "dXin", ",", "Xup", ",", "dXup"}], "}"}], "=", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"XHor", "[", "r0", "]"}], ",", 
        RowBox[{"YHor", "[", "r0", "]"}], ",", 
        RowBox[{"X\[Infinity]", "[", "r0", "]"}], ",", 
        RowBox[{"Y\[Infinity]", "[", "r0", "]"}]}], "}"}]}], ";", "\n", "\n", 
     RowBox[{"(*", " ", 
      RowBox[{
      "Remove", " ", "local", " ", "variables", " ", "not", " ", "garbage", 
       " ", "collected"}], "*)"}], "\n", 
     RowBox[{"Remove", "[", 
      RowBox[{"X", ",", "Y", ",", "r"}], "]"}], ";", "\n", 
     RowBox[{"{", 
      RowBox[{"Xin", ",", "dXin", ",", "Xup", ",", "dXup"}], "}"}]}]}], "\n", 
   "]"}]}]], "Code",
 CellChangeTimes->{{3.9469117123075867`*^9, 3.9469117148550124`*^9}, {
  3.94730881161547*^9, 3.947308847926783*^9}, {3.947310858198526*^9, 
  3.9473109143965487`*^9}, {3.947312943931252*^9, 3.9473129441802964`*^9}, {
  3.9473130331446*^9, 3.9473130534871798`*^9}, {3.9473130903471937`*^9, 
  3.9473131020057807`*^9}, {3.947313135468124*^9, 3.947313151743094*^9}, {
  3.94743300916276*^9, 3.9474330171186976`*^9}},
 CellLabel->
  "In[100]:=",ExpressionUUID->"0b567109-eb36-4c32-871c-ef9c7207a777"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"TeukolskyInUp", "[", 
    RowBox[{
    "r0_", ",", "\[CapitalOmega]_", ",", "m_", ",", "\[Lambda]_", ",", "Q_", 
     ",", "\[Delta]_"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "faux", ",", "\[CapitalDelta]", ",", "\[Eta]", ",", "\[Beta]", ",", 
       "\[Alpha]", ",", "c0", ",", "c1", ",", "c2", ",", "c3", ",", "c4", ",",
        "p1", ",", "q1", ",", "\[ScriptCapitalA]", ",", "\[ScriptCapitalB]", 
       ",", "Xin", ",", "Yin", ",", "Xup", ",", "Yup", ",", "Rin", ",", "Rup",
        ",", "dRin", ",", "dRup", ",", "Bin", ",", "\[ScriptCapitalD]trans", 
       ",", "kT", ",", "rp", ",", "rm"}], "}"}], ",", "\n", "\n", 
     RowBox[{
      RowBox[{"\[CapitalDelta]", "=", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"#", "^", "2"}], "-", 
          RowBox[{"2", " ", "M", " ", "#"}], " ", "+", " ", "Q"}], " ", ")"}],
         "&"}]}], ";", "\n", 
      RowBox[{"kT", "=", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"#", "^", "2"}], ")"}], "\[CapitalOmega]"}], " ", ")"}], 
        "&"}]}], ";", "\n", 
      RowBox[{"\[Beta]", "=", 
       RowBox[{
        RowBox[{"2", 
         RowBox[{"\[CapitalDelta]", "[", "#", "]"}], 
         RowBox[{"(", 
          RowBox[{
           RowBox[{
            RowBox[{"-", "I"}], " ", 
            RowBox[{"kT", "[", "#", "]"}]}], "+", "#", "-", "M", "-", 
           RowBox[{"2", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"\[CapitalDelta]", "[", "#", "]"}], "/", "#"}], 
             ")"}]}]}], ")"}]}], "&"}]}], ";", "\n", 
      RowBox[{"\[Alpha]", "=", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{
           RowBox[{"-", "I"}], " ", 
           RowBox[{"kT", " ", "[", "#", "]"}], 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"\[Beta]", "[", "#", "]"}], "/", 
             RowBox[{
              RowBox[{"\[CapitalDelta]", "[", "#", "]"}], "^", "2"}]}], 
            ")"}]}], "+", 
          RowBox[{"3", " ", "I", " ", 
           RowBox[{
            RowBox[{"kT", "'"}], "[", "#", "]"}]}], "+", "\[Lambda]", "+", 
          RowBox[{"6", " ", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"\[CapitalDelta]", "[", "#", "]"}], "/", 
             RowBox[{"#", "^", "2"}]}], ")"}]}]}], ")"}], "&"}]}], ";", "\n", 
      "\n", 
      RowBox[{"c0", "=", 
       RowBox[{
        RowBox[{"2", " ", "\[Lambda]"}], "+", 
        SuperscriptBox["\[Lambda]", "2"], "-", 
        RowBox[{"12", " ", "\[ImaginaryI]", " ", "\[CapitalOmega]"}]}]}], ";",
       "\[IndentingNewLine]", 
      RowBox[{"c1", "=", 
       RowBox[{
        RowBox[{
        "24", " ", "\[ImaginaryI]", " ", "Q", " ", "\[CapitalOmega]"}], "+", 
        RowBox[{
        "8", " ", "\[ImaginaryI]", " ", "Q", " ", "\[Delta]", " ", 
         "\[CapitalOmega]"}]}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"c2", "=", 
       RowBox[{
        RowBox[{"12", " ", "Q"}], "+", 
        RowBox[{"4", " ", "Q", " ", "\[Delta]"}], "-", 
        RowBox[{"4", " ", "Q", " ", "\[Delta]", " ", "\[Lambda]"}]}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"c3", "=", 
       RowBox[{
        RowBox[{
         RowBox[{"-", "24"}], " ", "Q"}], "-", 
        RowBox[{"24", " ", "Q", " ", "\[Delta]"}]}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"c4", "=", 
       RowBox[{
        RowBox[{"12", " ", 
         SuperscriptBox["Q", "2"]}], "+", 
        RowBox[{"16", " ", 
         SuperscriptBox["Q", "2"], " ", "\[Delta]"}]}]}], ";", "\n", 
      RowBox[{"\[Eta]", "=", 
       RowBox[{
        RowBox[{"c0", "+", 
         RowBox[{"c1", "/", "#"}], "+", 
         RowBox[{"c2", "/", 
          RowBox[{"#", "^", "2"}]}], "+", 
         RowBox[{"c3", "/", 
          RowBox[{"#", "^", "3"}]}], "+", 
         RowBox[{"c4", "/", 
          RowBox[{"#", "^", "4"}]}]}], "&"}]}], ";", "\n", "\n", 
      RowBox[{"faux", "=", 
       RowBox[{
        RowBox[{
         RowBox[{"\[CapitalDelta]", "[", "#", "]"}], "/", 
         RowBox[{"(", 
          RowBox[{"\[Sqrt]", 
           RowBox[{"(", 
            RowBox[{"#", "^", "2"}], ")"}]}], ")"}]}], "&"}]}], ";", "\n", 
      "\n", 
      RowBox[{"\[ScriptCapitalA]", "=", 
       RowBox[{
        RowBox[{"Evaluate", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"(", 
            RowBox[{"1", "/", 
             RowBox[{"\[Eta]", "[", "#", "]"}]}], ")"}], 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"\[Alpha]", "[", "#", "]"}], "+", 
             RowBox[{
              RowBox[{
               RowBox[{"\[Beta]", "'"}], "[", "#", "]"}], "/", 
              RowBox[{"\[CapitalDelta]", "[", "#", "]"}]}]}], ")"}], 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"\[CapitalDelta]", "[", "#", "]"}], "/", 
             RowBox[{"(", 
              RowBox[{"\[Sqrt]", 
               RowBox[{"(", 
                RowBox[{
                 RowBox[{"#", "^", "2"}], "+", 
                 RowBox[{"a", "^", "2"}]}], ")"}]}], ")"}]}], ")"}]}], "-", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"1", "/", 
             RowBox[{"\[Eta]", "[", "#", "]"}]}], ")"}], 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"\[Beta]", "[", "#", "]"}], "/", 
             RowBox[{"\[CapitalDelta]", "[", "#", "]"}]}], ")"}], " ", 
           RowBox[{
            RowBox[{"faux", "'"}], "[", "#", "]"}]}]}], "]"}], "&"}]}], ";", 
      "\n", 
      RowBox[{"\[ScriptCapitalB]", "=", 
       RowBox[{
        RowBox[{"Evaluate", "[", 
         RowBox[{
          RowBox[{"-", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"\[Beta]", "[", "#", "]"}], "/", 
             RowBox[{"\[Eta]", "[", "#", "]"}]}], ")"}]}], 
          RowBox[{"(", 
           RowBox[{"1", "/", 
            RowBox[{"(", 
             RowBox[{"\[Sqrt]", 
              RowBox[{"(", 
               RowBox[{"#", "^", "2"}], ")"}]}], ")"}]}], ")"}]}], "]"}], 
        "&"}]}], ";", "\n", "\n", 
      RowBox[{"p1", "=", 
       RowBox[{"pSN", "[", 
        RowBox[{
        "r0", ",", "\[CapitalOmega]", ",", "m", ",", "\[Lambda]", ",", "Q", 
         ",", "\[Delta]"}], "]"}]}], ";", "\n", 
      RowBox[{"q1", "=", 
       RowBox[{"qSN", "[", 
        RowBox[{
        "r0", ",", "\[CapitalOmega]", ",", "m", ",", "\[Lambda]", ",", "Q", 
         ",", "\[Delta]"}], "]"}]}], ";", "\n", "\n", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"Xin", ",", "Yin", ",", "Xup", ",", "Yup"}], "}"}], "=", 
       RowBox[{"homsolSN", "[", 
        RowBox[{
        "r0", ",", "\[CapitalOmega]", ",", "m", ",", "\[Lambda]", ",", "Q", 
         ",", "\[Delta]"}], "]"}]}], ";", "\n", "\n", 
      RowBox[{"\[ScriptCapitalD]trans", "=", 
       RowBox[{"-", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"4", 
            RowBox[{"\[CapitalOmega]", "^", "2"}]}], ")"}], "/", "c0"}], 
         ")"}]}]}], ";", "\n", "\n", " ", 
      RowBox[{"Rin", "=", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{
          RowBox[{"\[ScriptCapitalA]", "[", "r0", "]"}], " ", "Xin"}], "+", 
         RowBox[{
          RowBox[{"\[ScriptCapitalB]", " ", "[", "r0", "]"}], "Yin"}]}], 
        ")"}]}], ";", 
      RowBox[{"(*", 
       RowBox[{"Sasaki", "-", 
        RowBox[{"Nakamura", " ", "solution", " ", "to", " ", "Teukolsky"}]}], 
       "*)"}], "\n", " ", 
      RowBox[{"Rup", "=", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{
          RowBox[{"\[ScriptCapitalA]", "[", "r0", "]"}], " ", "Xup"}], "+", 
         RowBox[{
          RowBox[{"\[ScriptCapitalB]", "[", "r0", "]"}], " ", "Yup"}]}], 
        ")"}]}], ";", "\n", "\n", 
      RowBox[{"dRin", "=", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{
             RowBox[{"\[ScriptCapitalA]", "'"}], "[", "r0", "]"}], "-", 
            RowBox[{
             RowBox[{"\[ScriptCapitalB]", "[", "r0", "]"}], " ", "q1"}]}], 
           ")"}], "Xin"}], "+", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"\[ScriptCapitalA]", "[", "r0", "]"}], "+", 
            RowBox[{
             RowBox[{"\[ScriptCapitalB]", "'"}], "[", "r0", "]"}], "-", 
            RowBox[{
             RowBox[{"\[ScriptCapitalB]", "[", "r0", "]"}], " ", "p1"}]}], 
           ")"}], "Yin"}]}], ")"}]}], ";", "\n", 
      RowBox[{"dRup", "=", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{
             RowBox[{"\[ScriptCapitalA]", "'"}], "[", "r0", "]"}], "-", 
            RowBox[{
             RowBox[{"\[ScriptCapitalB]", " ", "[", "r0", "]"}], "q1"}]}], 
           ")"}], "Xup"}], "+", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"\[ScriptCapitalA]", "[", "r0", "]"}], "+", 
            RowBox[{
             RowBox[{"\[ScriptCapitalB]", "'"}], "[", "r0", "]"}], "-", 
            RowBox[{
             RowBox[{"\[ScriptCapitalB]", "[", "r0", "]"}], " ", "p1"}]}], 
           ")"}], "Yup"}]}], ")"}]}], ";", "\n", "\n", 
      RowBox[{"Bin", "=", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"1", "/", 
          RowBox[{"(", 
           RowBox[{"2", " ", "I", " ", "\[CapitalOmega]", " ", 
            RowBox[{"\[CapitalDelta]", "[", "r0", "]"}], 
            "\[ScriptCapitalD]trans"}], ")"}]}], ")"}], 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"Rin", " ", "dRup"}], "-", 
