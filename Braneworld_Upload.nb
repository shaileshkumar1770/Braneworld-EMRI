Cell[BoxData[
 RowBox[{
  RowBox[{"SetAttributes", "[", 
   RowBox[{"SpinWeightedSphericalHarmonicY", ",", " ", 
    RowBox[{"{", 
     RowBox[{"NumericFunction", ",", " ", "Listable"}], "}"}]}], "]"}], 
