Cell[CellGroupData[{

Cell["Continued fraction", "Subsubsection",ExpressionUUID->"dd7da138-3cbf-4ba2-879c-2da2bacb44a2"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"CF", "[", 
     RowBox[{"a_", ",", " ", "b_", ",", " ", 
      RowBox[{"{", 
       RowBox[{"n_", ",", " ", "n0_"}], "}"}]}], "]"}], " ", ":=", " ", "\n", 
    "  ", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"A", ",", " ", "B", ",", " ", "ak", ",", " ", "bk", ",", " ", 
        RowBox[{"res", " ", "=", " ", "Indeterminate"}], ",", " ", 
        RowBox[{"j", " ", "=", " ", "n0"}]}], "}"}], ",", "\n", "   ", 
      RowBox[{
       RowBox[{
        RowBox[{"A", "[", 
         RowBox[{"n0", " ", "-", " ", "2"}], "]"}], " ", "=", " ", "1"}], ";",
        "\n", "   ", 
       RowBox[{
        RowBox[{"B", "[", 
         RowBox[{"n0", " ", "-", " ", "2"}], "]"}], " ", "=", " ", "0"}], ";",
        "\n", "   ", 
       RowBox[{
        RowBox[{"ak", "[", "k_", "]"}], " ", ":=", " ", 
        RowBox[{
         RowBox[{"ak", "[", "k", "]"}], " ", "=", " ", 
         RowBox[{"(", 
          RowBox[{"a", " ", "/.", " ", 
           RowBox[{"n", " ", "->", " ", "k"}]}], ")"}]}]}], ";", "\n", "   ", 
       RowBox[{
        RowBox[{"bk", "[", "k_", "]"}], " ", ":=", " ", 
        RowBox[{
         RowBox[{"bk", "[", "k", "]"}], " ", "=", " ", 
         RowBox[{"(", 
          RowBox[{"b", " ", "/.", " ", 
           RowBox[{"n", " ", "->", " ", "k"}]}], ")"}]}]}], ";", "\n", "   ", 
       RowBox[{
        RowBox[{"A", "[", 
         RowBox[{"n0", " ", "-", " ", "1"}], "]"}], " ", "=", " ", "0"}], 
       RowBox[{"(*", 
        RowBox[{"bk", "[", 
         RowBox[{"n0", "-", "1"}], "]"}], "*)"}], ";", "\n", "   ", 
       RowBox[{
        RowBox[{"B", "[", 
         RowBox[{"n0", " ", "-", " ", "1"}], "]"}], " ", "=", " ", "1"}], ";",
        "\n", "   ", 
       RowBox[{
        RowBox[{"A", "[", "k_", "]"}], " ", ":=", " ", 
        RowBox[{
         RowBox[{"A", "[", "k", "]"}], " ", "=", " ", 
         RowBox[{
          RowBox[{
           RowBox[{"bk", "[", "k", "]"}], " ", 
           RowBox[{"A", "[", 
            RowBox[{"k", " ", "-", " ", "1"}], "]"}]}], " ", "+", " ", 
          RowBox[{
           RowBox[{"ak", "[", "k", "]"}], " ", 
           RowBox[{"A", "[", 
            RowBox[{"k", " ", "-", " ", "2"}], "]"}]}]}]}]}], ";", "\n", 
       "   ", 
       RowBox[{
        RowBox[{"B", "[", "k_", "]"}], " ", ":=", " ", 
        RowBox[{
         RowBox[{"B", "[", "k", "]"}], " ", "=", " ", 
         RowBox[{
          RowBox[{
           RowBox[{"bk", "[", "k", "]"}], " ", 
           RowBox[{"B", "[", 
            RowBox[{"k", " ", "-", " ", "1"}], "]"}]}], " ", "+", " ", 
          RowBox[{
           RowBox[{"ak", "[", "k", "]"}], " ", 
           RowBox[{"B", "[", 
            RowBox[{"k", " ", "-", " ", "2"}], "]"}]}]}]}]}], ";", "\n", 
       "   ", 
       RowBox[{"While", "[", 
        RowBox[{
         RowBox[{"res", " ", "=!=", " ", 
          RowBox[{"(", 
           RowBox[{"res", " ", "=", " ", 
            RowBox[{
             RowBox[{"A", "[", "j", "]"}], "/", 
             RowBox[{"B", "[", "j", "]"}]}]}], ")"}]}], ",", " ", 
         RowBox[{"j", "++"}]}], "]"}], ";", "\n", "   ", 
       RowBox[{"Clear", "[", 
        RowBox[{"A", ",", " ", "B", ",", " ", "ak", ",", " ", "bk"}], "]"}], 
       ";", "\n", "   ", "res"}]}], "\n", "   ", "]"}]}], ";"}], 
  "\n"}]], "Code",
 CellLabel->"In[30]:=",ExpressionUUID->"63e7f551-fa84-479c-8e4c-209ac7376ae7"]
}, Open  ]]
