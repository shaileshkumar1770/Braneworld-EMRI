         RowBox[{"(", 
          RowBox[{
           RowBox[{"\[Kappa]", "^", "2"}], "+", 
           RowBox[{"4", 
            RowBox[{"\[Epsilon]", "^", "2"}]}]}], ")"}], 
         RowBox[{"(", 
          RowBox[{
