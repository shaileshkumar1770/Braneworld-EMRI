          RowBox[{"Leaver", "'"}], "s", " ", "recurrence", " ", "formula"}], 
         ",", " ", 
         RowBox[{
          RowBox[{"Eq", ".", " ", "20"}], " ", "of", " ", "Leaver", " ", 
          "1985"}]}], " ", "*)"}], "\n", "  ", 
       RowBox[{"k1", " ", "=", " ", 
        RowBox[{
         RowBox[{"Abs", "[", 
          RowBox[{"m", "-", "s"}], "]"}], "/", "2"}]}], ";", "\n", "  ", 
