Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"\[CapitalOmega]ceoDM", "[", 
    RowBox[{"r0_", ",", "Q_", ",", 
     RowBox[{"orbit_", "?", "StringQ"}]}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"Delta", ",", "OrbitFreq", ",", "rp", ",", "rm"}], "}"}], ",", 
     "\n", 
     RowBox[{
      RowBox[{"Delta", "=", 
       RowBox[{
        RowBox[{"r0", "^", "2"}], " ", "-", " ", 
        RowBox[{"2", " ", "M", " ", "r0"}], " ", "+", " ", "Q"}]}], ";", "\n", 
      RowBox[{
       RowBox[{"OrbitFreq", "[", "sgn_", "]"}], ":=", 
       RowBox[{"Block", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"U0", ",", "U3", ",", "UmpProRet", ",", "\[CapitalOmega]"}],
           "}"}], ",", "\n", 
         RowBox[{
          RowBox[{"UmpProRet", "=", 
           RowBox[{
            RowBox[{"-", 
             RowBox[{"(", 
              RowBox[{"sgn", " ", 
               RowBox[{"Sqrt", "[", "r0", "]"}]}], ")"}]}], "/", 
            RowBox[{"Sqrt", "[", "Delta", "]"}]}]}], ";", 
          RowBox[{"(*", 
           RowBox[{
            RowBox[{
             RowBox[{"sgn", " ", "-", "1"}], ":", " ", "corotating"}], ";", 
            " ", 
            RowBox[{"1", ":", 
             RowBox[{"counter", " ", "rotating"}]}]}], "*)"}], "\n", 
          RowBox[{"U0", "=", 
           RowBox[{"1", "/", 
            RowBox[{"Sqrt", "[", 
             RowBox[{"1", "-", 
              RowBox[{"UmpProRet", "^", "2"}]}], "]"}]}]}], ";", "\n", 
          RowBox[{"U3", "=", 
           RowBox[{"UmpProRet", "/", 
            RowBox[{"Sqrt", "[", 
             RowBox[{"1", "-", 
              RowBox[{"UmpProRet", "^", "2"}]}], "]"}]}]}], ";", "\n", 
          RowBox[{"\[CapitalOmega]", "=", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{
              RowBox[{"Sqrt", "[", "Delta", "]"}], " ", "U3"}], ")"}], "/", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{"r0", "^", "2"}], ")"}], "U0"}], ")"}]}]}], ";", "\n", 
          "\[CapitalOmega]"}]}], "\n", "]"}]}], ";", "\n", "\n", 
      RowBox[{"Which", "[", 
       RowBox[{
        RowBox[{"orbit", "==", "\"\<pro\>\""}], ",", "\n", 
        RowBox[{"OrbitFreq", "[", 
         RowBox[{"-", "1"}], "]"}], ",", "\n", 
        RowBox[{"orbit", "==", "\"\<ret\>\""}], ",", "\n", 
        RowBox[{"OrbitFreq", "[", "1", "]"}]}], "\n", "]"}]}]}], "\n", 
    "]"}]}], "\n"}]], "Code",
