Cell[CellGroupData[{

Cell["Leaver' s method", "Subsection",ExpressionUUID->"b47c6abf-e411-4395-bdeb-6bf4e8020f98"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"Options", "[", "SWSHEigenvalueLeaver", "]"}], " ", "=", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
      "\"\<InitialGuess\>\"", " ", "->", " ", "\"\<SphericalExpansion\>\""}], 
      ",", " ", 
      RowBox[{"\"\<NumInversions\>\"", " ", "->", " ", "Automatic"}]}], 
     "}"}]}], ";"}], "\n"}]], "Code",
