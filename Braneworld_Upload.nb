                "\[CapitalDelta]"}], " ", "\[ScriptCapitalA]2"}]}], ")"}], 
            "dRin"}]}]}], ";", "\n", 
         RowBox[{"ZH", "=", 
          RowBox[{
           RowBox[{"1", "/", 
            RowBox[{"(", 
             RowBox[{"2", "I", " ", "Bin"}], ")"}]}], " ", "2", "\[Pi]", " ", 
           "\[ScriptCapitalI]H"}]}], ";", "\n", 
         RowBox[{"\[ScriptCapitalI]\[Infinity]", "=", 
          RowBox[{
           RowBox[{
            RowBox[{"(", 
             RowBox[{"\[ScriptCapitalA]0", "+", 
              RowBox[{"\[ScriptCapitalA]2", " ", 
               RowBox[{
                RowBox[{"VT", "[", "r0", "]"}], "/", "\[CapitalDelta]"}]}]}], 
             ")"}], "Rup"}], "+", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{
              RowBox[{"-", "\[ScriptCapitalA]1"}], "+", 
              RowBox[{
               RowBox[{
                RowBox[{"(", 
                 RowBox[{"2", 
                  RowBox[{"(", 
                   RowBox[{"r0", "-", "M"}], ")"}]}], ")"}], "/", 
                "\[CapitalDelta]"}], " ", "\[ScriptCapitalA]2"}]}], ")"}], 
            "dRup"}]}]}], ";", "\n", 
         RowBox[{"dlm\[Omega]", "=", 
          RowBox[{
           RowBox[{"Sqrt", "[", 
            RowBox[{"2", "M", " ", "rHout"}], "]"}], 
           RowBox[{"(", 
            RowBox[{
             RowBox[{
              RowBox[{"(", 
               RowBox[{"8", "-", 
                RowBox[{"24", " ", "I", " ", "M", " ", "\[CapitalOmega]"}], 
                "-", 
                RowBox[{"16", " ", 
                 RowBox[{"M", "^", "2"}], " ", 
                 RowBox[{"\[CapitalOmega]", "^", "2"}]}]}], ")"}], 
              RowBox[{
               RowBox[{"(", "rHout", ")"}], "^", "2"}]}], "+", 
             RowBox[{
              RowBox[{"(", " ", 
               RowBox[{
                RowBox[{
                 RowBox[{"-", "16"}], " ", "M"}], " ", "+", 
                RowBox[{"24", " ", "I", " ", 
                 RowBox[{"M", "^", "2"}], " ", "\[CapitalOmega]"}]}], ")"}], 
              "rHout"}], "+", 
             RowBox[{"8", 
              RowBox[{"M", "^", "2"}]}]}], ")"}]}]}], ";", "\n", 
         RowBox[{"c0", "=", 
          RowBox[{
           RowBox[{
            RowBox[{"-", "12"}], "I", " ", "\[CapitalOmega]", " ", "M"}], "+", 
           RowBox[{"\[CapitalLambda]", 
            RowBox[{"(", 
             RowBox[{"\[CapitalLambda]", "+", "2"}], ")"}]}]}]}], ";", "\n", 
         RowBox[{"\[ScriptCapitalD]trans", "=", 
          RowBox[{"-", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{"4", 
               RowBox[{"\[CapitalOmega]", "^", "2"}]}], ")"}], "/", "c0"}], 
            ")"}]}]}], ";", "\n", 
         RowBox[{"Z\[Infinity]", "=", 
          RowBox[{
           RowBox[{"1", "/", 
            RowBox[{"(", 
             RowBox[{"2", "I", " ", "\[CapitalOmega]", " ", "Bin"}], ")"}]}], 
           " ", 
           RowBox[{"1", "/", "dlm\[Omega]"}], " ", 
           RowBox[{"1", "/", "\[ScriptCapitalD]trans"}], " ", "2", "\[Pi]", 
           " ", "\[ScriptCapitalI]\[Infinity]"}]}], ";", " ", "\n", 
         RowBox[{"{", 
          RowBox[{"ZH", ",", "Z\[Infinity]"}], "}"}]}]}], "\n", "]"}]}], ";", 
     "\n", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"xa", ",", "xb", ",", "nS"}], "}"}], "=", 
      RowBox[{"{", 
       RowBox[{"0", ",", "\[Pi]", ",", "6"}], "}"}]}], ";", "\n", 
     RowBox[{"hstep", "=", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"xb", "-", "xa"}], ")"}], "/", "nS"}]}], ";", "\n", 
     RowBox[{"xlist", "=", 
      RowBox[{"Range", "[", 
       RowBox[{"xa", ",", "xb", ",", "hstep"}], "]"}]}], ";", "\n", 
     RowBox[{"ZHAmpZ\[Infinity]AmData", "=", 
      RowBox[{"Sum", "[", 
       RowBox[{
        RowBox[{"ampComp", "[", 
         RowBox[{"xlist", "[", 
          RowBox[{"[", "i", "]"}], "]"}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"i", ",", "2", ",", 
          RowBox[{
           RowBox[{"Length", "[", "xlist", "]"}], "-", "1"}]}], "}"}]}], 
       "]"}]}], ";", "\n", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"ZHAmp", ",", "Z\[Infinity]Amp"}], "}"}], "=", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"ampComp", "[", 
          RowBox[{"xlist", "[", 
           RowBox[{"[", "1", "]"}], "]"}], "]"}], "+", 
         RowBox[{"ampComp", "[", 
          RowBox[{"xlist", "[", 
           RowBox[{"[", 
            RowBox[{"Length", "[", "xlist", "]"}], "]"}], "]"}], "]"}], "+", 
         RowBox[{"2", " ", "ZHAmpZ\[Infinity]AmData"}]}], ")"}], 
       RowBox[{"hstep", "/", "2"}]}]}], ";", "\n", 
     RowBox[{"<|", "\n", 
      RowBox[{
       RowBox[{"\"\<ampZH\>\"", "->", "ZHAmp"}], ",", "\n", 
