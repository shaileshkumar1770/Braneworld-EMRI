      RowBox[{"ZHZIdata", "[", "\"\<\[CapitalLambda]\>\"", "]"}]}], ";", "\n", 
     RowBox[{"\[Kappa]", "=", "\[CapitalOmega]"}], ";", "\n", 
     RowBox[{"\[Epsilon]", "=", 
      RowBox[{
       RowBox[{"Sqrt", "[", 
        RowBox[{"M", "^", "2"}], "]"}], "/", 
       RowBox[{"(", 
        RowBox[{"4", "M", " ", "rHout"}], ")"}]}]}], ";", "\n", 
