Cell[CellGroupData[{

Cell["Energy and angular momentum circular orbit equatorial plane", \
"Subsubsection",ExpressionUUID->"478d0a34-ba86-4602-945d-c9abc455b13b"],

Cell[BoxData[
 RowBox[{
  RowBox[{"EnLz", "[", 
   RowBox[{"r0_", ",", "Q_", ",", 
    RowBox[{"orbit_", "?", "StringQ"}]}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "En", ",", "Lz", ",", "Delta", ",", "rp", ",", "rm", ",", 
      "eneranarmoment"}], "}"}], ",", "\n", "\n", 
    RowBox[{
     RowBox[{"Delta", "=", 
      RowBox[{
       RowBox[{"r0", "^", "2"}], " ", "-", " ", 
       RowBox[{"2", " ", "M", " ", "r0"}], " ", "+", " ", "Q"}]}], ";", "\n", 
     "\n", 
     RowBox[{
      RowBox[{"eneranarmoment", "[", "sgn_", "]"}], ":=", 
      RowBox[{"Block", "[", 
       RowBox[{
        RowBox[{"{", "UmpProRet", "}"}], ",", "\n", 
        RowBox[{
         RowBox[{"UmpProRet", "=", 
          RowBox[{
           RowBox[{"-", 
            RowBox[{"(", 
             RowBox[{"sgn", " ", 
              RowBox[{"Sqrt", "[", "r0", "]"}]}], ")"}]}], "/", 
           RowBox[{"Sqrt", "[", "Delta", "]"}]}]}], ";", 
         RowBox[{"(*", 
          RowBox[{
           RowBox[{
            RowBox[{"sgn", " ", "-", "1"}], ":", " ", "corotating"}], ";", 
           " ", 
           RowBox[{"1", ":", 
            RowBox[{"counter", " ", "rotating"}]}]}], "*)"}], "\n", 
         RowBox[{"En", "=", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"r0", " ", 
             RowBox[{"Sqrt", "[", "Delta", "]"}]}], ")"}], "/", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"r0", "^", "2"}], "  ", 
             RowBox[{"Sqrt", "[", 
              RowBox[{"1", "-", 
               RowBox[{"UmpProRet", "^", "2"}]}], "]"}]}], ")"}]}]}], ";", 
         "\n", 
         RowBox[{"Lz", "=", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{"r0", "^", "2"}], ")"}], "UmpProRet"}], ")"}], "/", 
           RowBox[{"(", 
            RowBox[{"r0", " ", 
             RowBox[{"Sqrt", "[", 
              RowBox[{"1", "-", 
               RowBox[{"UmpProRet", "^", "2"}]}], "]"}]}], ")"}]}]}], ";", 
         "\n", 
         RowBox[{"{", 
          RowBox[{"En", ",", "Lz"}], "}"}]}]}], "\n", "]"}]}], ";", "\n", 
     "\n", 
     RowBox[{"Which", "[", 
      RowBox[{
       RowBox[{"orbit", "==", "\"\<pro\>\""}], ",", "\n", 
       RowBox[{"eneranarmoment", "[", 
        RowBox[{"-", "1"}], "]"}], ",", "\n", 
       RowBox[{"orbit", "==", "\"\<ret\>\""}], ",", "\n", 
       RowBox[{"eneranarmoment", "[", "1", "]"}]}], "\n", "]"}]}]}], "\n", 
   "]"}]}]], "Code",
 CellChangeTimes->{{3.946911628146552*^9, 3.946911628325147*^9}, {
  3.947310538621642*^9, 3.947310585272505*^9}, {3.9474325871122665`*^9, 
  3.947432587641583*^9}},
 CellLabel->"In[90]:=",ExpressionUUID->"55438b05-263d-41b7-9fc9-d2c4f043af8c"]
