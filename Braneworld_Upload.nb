            RowBox[{"mm", "'"}]}], "]"}]}]}], " ", "*)"}], "\n", "  ", 
       RowBox[{"norm", " ", "=", " ", 
        RowBox[{
         RowBox[{"Sqrt", "[", 
          RowBox[{"2", "\[Pi]"}], "]"}], " ", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"2", "^", 
             RowBox[{"(", 
              RowBox[{"1", "+", 
               RowBox[{"2", " ", "k1"}], "+", 
               RowBox[{"2", " ", "k2"}]}], ")"}]}], " ", 
