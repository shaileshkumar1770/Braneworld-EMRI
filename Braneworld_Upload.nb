              RowBox[{"n", "-", "2"}], "]"}]}]}], ")"}], "/", 
          RowBox[{"\[Alpha]n", "[", 
           RowBox[{"n", "-", "1"}], "]"}]}]}]}], ";", "\n", "\n", "  ", 
       RowBox[{"(*", " ", 
        RowBox[{
        "Compute", " ", "coefficients", " ", "until", " ", "we", " ", "reach",
