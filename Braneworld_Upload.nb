          RowBox[{
           RowBox[{"i", "+", 
            RowBox[{"2", " ", 
             RowBox[{"(", 
              RowBox[{"1", "+", "k1", "+", "k2"}], ")"}]}]}], ",", " ", 
           RowBox[{
            RowBox[{
             RowBox[{"-", "2"}], "k2"}], "-", "1"}]}], "]"}], " ", 
