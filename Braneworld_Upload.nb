               RowBox[{"n", "-", "1"}], "]"}]}], 
             RowBox[{"an", "[", 
              RowBox[{"n", "-", "1"}], "]"}]}], "-", 
            RowBox[{
             RowBox[{"\[Gamma]n", "[", 
              RowBox[{"n", "-", "1"}], "]"}], 
