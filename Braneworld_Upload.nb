Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"SpinWeightedSpheroidalEigenvalue", " ", "/:", " ", "\n", "  ", 
    RowBox[{"Series", "[", 
     RowBox[{
      RowBox[{"SpinWeightedSpheroidalEigenvalue", "[", 
       RowBox[{"s_", ",", " ", "l_", ",", " ", "m_", ",", " ", "\[Gamma]_"}], 
       "]"}], ",", " ", 
      RowBox[{"{", 
       RowBox[{"\[Gamma]_", ",", " ", "0", ",", " ", "order_"}], "}"}]}], 
     "]"}], " ", ":=", " ", "\n", " ", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"i", ",", " ", "j", ",", " ", "coeffs"}], "}"}], ",", " ", 
      RowBox[{"Internal`InheritedBlock", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"d", ",", " ", "s\[Lambda]lm"}], "}"}], ",", " ", 
        RowBox[{"Block", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"\[Alpha]", ",", " ", "\[Beta]"}], "}"}], ",", "\n", "  ", 
          RowBox[{
           RowBox[{"Do", "[", "\n", "    ", 
            RowBox[{
             RowBox[{
              RowBox[{"Do", "[", "\n", "      ", 
               RowBox[{
                RowBox[{
                 RowBox[{
                  RowBox[{"d", "[", 
                   RowBox[{"s", ",", " ", "l", ",", " ", "m"}], "]"}], "[", 
                  RowBox[{"i", ",", " ", "j"}], "]"}], " ", "=", " ", 
                 RowBox[{"simplify", "[", 
                  RowBox[{
                   RowBox[{"d", "[", 
                    RowBox[{"s", ",", " ", "l", ",", " ", "m"}], "]"}], "[", 
                   RowBox[{"i", ",", " ", "j"}], "]"}], "]"}]}], ",", " ", 
                RowBox[{"{", 
                 RowBox[{"j", ",", " ", 
                  RowBox[{"-", "i"}], ",", " ", "i"}], "}"}]}], "]"}], ";", 
              " ", "\n", "    ", 
              RowBox[{
               RowBox[{
                RowBox[{"s\[Lambda]lm", "[", 
                 RowBox[{"s", ",", " ", "l", ",", " ", "m"}], "]"}], "[", "i",
                 "]"}], " ", "=", " ", 
               RowBox[{"simplify", "[", 
                RowBox[{
                 RowBox[{"s\[Lambda]lm", "[", 
                  RowBox[{"s", ",", " ", "l", ",", " ", "m"}], "]"}], "[", 
                 "i", "]"}], "]"}]}], ";"}], "\n", "  ", ",", " ", 
             RowBox[{"{", 
              RowBox[{"i", ",", " ", "0", ",", " ", "order"}], "}"}]}], "]"}],
            ";", "\n", "  ", 
           RowBox[{"coeffs", " ", "=", " ", 
            RowBox[{"Table", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"s\[Lambda]lm", "[", 
                RowBox[{"s", ",", " ", "l", ",", " ", "m"}], "]"}], "[", "i", 
               "]"}], ",", " ", 
              RowBox[{"{", 
               RowBox[{"i", ",", " ", "0", ",", " ", "order"}], "}"}]}], 
             "]"}]}], ";", "\n", "  ", 
           RowBox[{"SeriesData", "[", 
            RowBox[{
            "\[Gamma]", ",", " ", "0", ",", " ", "coeffs", ",", " ", "0", ",",
              " ", 
             RowBox[{"order", " ", "+", " ", "1"}], ",", " ", "1"}], 
            "]"}]}]}], "\n", "]"}]}], "]"}]}], "]"}]}], ";"}], "\n"}]], "Code",
 CellLabel->"In[42]:=",ExpressionUUID->"ee92f985-ba2a-47ba-abee-176138957c1c"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Large - \[Gamma] expansion", "Subsection",
