Cell["\<\
For details see \"High-order asymptotics for the Spin-Weighted Spheroidal \
Equation at large \[LineSeparator]real frequency\", M. Casals, A. C. \
Ottewill, N. Warburton, arXiv : 1810.00432\
\>", "Text",
 CellChangeTimes->{
  3.947476274089881*^9},ExpressionUUID->"d06da9ee-8bef-408e-b0b0-\
19e7f1d2cade"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"SWSHq", "[", 
    RowBox[{
     RowBox[{"s_", "?", "NumberQ"}], ",", " ", 
     RowBox[{"l_", "?", "NumberQ"}], ",", " ", 
     RowBox[{"m_", "?", "NumberQ"}]}], "]"}], " ", ":=", " ", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"slm", ",", "z0"}], "}"}], ",", "\n", "\t", 
     RowBox[{
      RowBox[{"slm", " ", "=", " ", 
       RowBox[{
        RowBox[{"Abs", "[", 
         RowBox[{"m", "+", 
          RowBox[{"Abs", "[", "s", "]"}]}], "]"}], " ", "+", " ", 
        RowBox[{"Abs", "[", "s", "]"}]}]}], ";", "\n", "\t", 
      RowBox[{"z0", "  ", "=", " ", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"EvenQ", "[", 
          RowBox[{"l", "+", "m"}], "]"}], ",", " ", "0", ",", " ", "1"}], 
        "]"}]}], ";", "\n", "\n", "\t", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"l", "  ", ">=", " ", "slm"}], ",", " ", 
        RowBox[{"l", "+", "1", "-", "z0"}], ",", "  ", 
        RowBox[{
         RowBox[{"2", "l"}], "+", "1", " ", "-", " ", "slm"}]}], " ", 
       "]"}]}]}], "\n", "]"}]}], "\n"}]], "Code",
 CellLabel->"In[43]:=",ExpressionUUID->"f68e397b-e05c-4ed5-ba9c-94a218652c54"],

Cell[BoxData[
 RowBox[{
  RowBox[{"SpinWeightedSpheroidalEigenvalue", " ", "/:", " ", "\n", "  ", 
   RowBox[{"Series", "[", 
    RowBox[{
     RowBox[{"SpinWeightedSpheroidalEigenvalue", "[", 
      RowBox[{
       RowBox[{"s_", "?", "NumberQ"}], ",", " ", 
       RowBox[{"l_", "?", "NumberQ"}], ",", " ", 
       RowBox[{"m_", "?", "NumberQ"}], ",", " ", 
       RowBox[{"-", "\[Gamma]_"}]}], "]"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"\[Gamma]_", ",", " ", "\[Infinity]", ",", " ", "order_"}], 
      "}"}]}], "]"}], ":=", " ", 
   RowBox[{"Series", "[", 
    RowBox[{
     RowBox[{"SpinWeightedSpheroidalEigenvalue", "[", 
      RowBox[{"s", ",", " ", "l", ",", " ", 
       RowBox[{"-", "m"}], ",", " ", "\[Gamma]"}], "]"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"\[Gamma]", ",", " ", "\[Infinity]", ",", " ", "order"}], 
      "}"}]}], "]"}]}], "\n"}]], "Code",
