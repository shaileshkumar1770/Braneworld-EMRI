     RowBox[{"{", 
      RowBox[{"\[Gamma]_", ",", " ", "0", ",", " ", "order_"}], "}"}]}], 
    "]"}], " ", ":=", "\n", " ", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"i", ",", " ", "j", ",", " ", "coeffs"}], "}"}], ",", " ", 
     RowBox[{"Internal`InheritedBlock", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"d", ",", " ", "s\[Lambda]lm"}], "}"}], ",", " ", 
       RowBox[{"Block", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"\[Alpha]", ",", " ", "\[Beta]"}], "}"}], ",", "\n", "  ", 
         RowBox[{
          RowBox[{"Do", "[", "\n", "    ", 
           RowBox[{
            RowBox[{
             RowBox[{"Do", "[", "\n", "      ", 
              RowBox[{
               RowBox[{
                RowBox[{
                 RowBox[{"d", "[", 
                  RowBox[{"s", ",", " ", "l", ",", " ", "m"}], "]"}], "[", 
                 RowBox[{"i", ",", " ", "j"}], "]"}], " ", "=", " ", 
                RowBox[{"simplify", "[", 
                 RowBox[{
                  RowBox[{"d", "[", 
                   RowBox[{"s", ",", " ", "l", ",", " ", "m"}], "]"}], "[", 
                  RowBox[{"i", ",", " ", "j"}], "]"}], "]"}]}], ",", " ", 
               RowBox[{"{", 
                RowBox[{"j", ",", " ", 
                 RowBox[{"-", "i"}], ",", " ", "i"}], "}"}]}], "]"}], ";", 
             " ", "\n", "    ", 
             RowBox[{
              RowBox[{
               RowBox[{"s\[Lambda]lm", "[", 
                RowBox[{"s", ",", " ", "l", ",", " ", "m"}], "]"}], "[", "i", 
               "]"}], " ", "=", " ", 
              RowBox[{"simplify", "[", 
               RowBox[{
                RowBox[{"s\[Lambda]lm", "[", 
                 RowBox[{"s", ",", " ", "l", ",", " ", "m"}], "]"}], "[", "i",
                 "]"}], "]"}]}], ";"}], "\n", "  ", ",", " ", 
            RowBox[{"{", 
             RowBox[{"i", ",", " ", "0", ",", " ", "order"}], "}"}]}], "]"}], 
          ";", "\n", "  ", 
          RowBox[{"coeffs", " ", "=", " ", 
           RowBox[{"Table", "[", 
            RowBox[{
             RowBox[{"Sum", "[", 
              RowBox[{
               RowBox[{
                RowBox[{
                 RowBox[{"d", "[", 
                  RowBox[{"s", ",", " ", "l", ",", " ", "m"}], "]"}], "[", 
                 RowBox[{"i", ",", " ", "j"}], "]"}], " ", 
                RowBox[{"SpinWeightedSphericalHarmonicY", "[", 
                 RowBox[{"s", ",", " ", 
                  RowBox[{"l", "+", "j"}], ",", " ", "m", ",", " ", 
                  "\[Theta]", ",", " ", "\[Phi]"}], "]"}]}], ",", " ", 
               RowBox[{"{", 
                RowBox[{"j", ",", " ", 
                 RowBox[{"-", "i"}], ",", " ", "i"}], "}"}]}], "]"}], ",", 
             " ", 
             RowBox[{"{", 
              RowBox[{"i", ",", " ", "0", ",", " ", "order"}], "}"}]}], 
            "]"}]}], ";", "\n", "  ", 
          RowBox[{"SeriesData", "[", 
           RowBox[{
           "\[Gamma]", ",", " ", "0", ",", " ", "coeffs", ",", " ", "0", ",", 
            " ", 
            RowBox[{"order", " ", "+", " ", "1"}], ",", " ", "1"}], "]"}]}]}],
         "\n", "]"}]}], "]"}]}], "]"}]}], ";"}]], "Code",
 CellLabel->"In[58]:=",ExpressionUUID->"1f340de0-34b8-4010-9ab4-73399e46bf95"]
