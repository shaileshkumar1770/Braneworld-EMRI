      "s_Integer", ",", " ", "l_Integer", ",", " ", "m_Integer", ",", " ", 
       RowBox[{"\[Gamma]_", "?", "InexactNumberQ"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{
        "method_String", ",", " ", "coeffs_List", ",", " ", "nDown_Integer", 
         ",", " ", "nUp_Integer"}], "}"}]}], "]"}], "[", 
     RowBox[{
      RowBox[{"\[Theta]_", "?", "NumericQ"}], ",", " ", 
      RowBox[{"\[Phi]_", "?", "NumericQ"}]}], "]"}], " ", ":=", "\n", " ", 
    RowBox[{
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"u", " ", "=", " ", 
          RowBox[{"Cos", "[", "\[Theta]", "]"}]}], ",", " ", 
         RowBox[{"k1", " ", "=", " ", 
          RowBox[{
           RowBox[{"Abs", "[", 
            RowBox[{"m", "-", "s"}], "]"}], "/", "2"}]}], ",", " ", 
         RowBox[{"k2", " ", "=", " ", 
          RowBox[{
           RowBox[{"Abs", "[", 
            RowBox[{"m", "+", "s"}], "]"}], "/", "2"}]}], ",", " ", 
         "oneplusu", ",", " ", "oneminusu", ",", " ", "res"}], "}"}], ",", 
       "\n", "  ", 
       RowBox[{
        RowBox[{"oneplusu", " ", "=", " ", 
         RowBox[{"2", " ", 
          RowBox[{
           RowBox[{"Cos", "[", 
            RowBox[{"\[Theta]", "/", "2"}], "]"}], "^", "2"}]}]}], ";", "\n", 
        "  ", 
        RowBox[{"oneminusu", " ", "=", " ", 
         RowBox[{"2", " ", 
          RowBox[{
           RowBox[{"Sin", "[", 
            RowBox[{"\[Theta]", "/", "2"}], "]"}], "^", "2"}]}]}], ";", "\n", 
        "  ", 
        RowBox[{"(*", " ", 
         RowBox[{
          RowBox[{
           RowBox[{"Leaver", "'"}], "s", " ", "series", " ", "solution"}], 
          ",", " ", 
          RowBox[{
           RowBox[{"Eq", ".", " ", "18"}], " ", "of", " ", "Leaver", " ", 
           "1985"}]}], " ", "*)"}], "\n", "  ", 
        RowBox[{"res", " ", "=", " ", 
         RowBox[{
          RowBox[{"E", "^", 
           RowBox[{"(", 
            RowBox[{"\[Gamma]", " ", "u"}], ")"}]}], " ", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{"k1", "==", "0"}], ",", " ", "1", ",", " ", 
            RowBox[{"oneplusu", "^", "k1"}]}], "]"}], " ", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{"k2", "==", "0"}], ",", " ", "1", ",", " ", 
            RowBox[{"oneminusu", "^", "k2"}]}], "]"}], " ", 
          RowBox[{"coeffs", " ", ".", " ", 
           RowBox[{"oneplusu", "^", 
            RowBox[{"Range", "[", 
             RowBox[{"0", ",", "nUp"}], "]"}]}]}], " ", 
          RowBox[{"Exp", "[", 
           RowBox[{"I", " ", "m", " ", "\[Phi]"}], "]"}]}]}], ";", "\n", "\n",
         "  ", 
        RowBox[{"(*", " ", 
         RowBox[{
         "Print", " ", "a", " ", "warning", " ", "message", " ", "if", " ", 
          "the", " ", "harmonic", " ", "cannot", " ", "be", " ", 
          "determined"}], " ", "*)"}], "\n", "  ", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"Precision", "[", "res", "]"}], " ", "==", " ", "0."}], 
           " ", "&&", " ", 
           RowBox[{
            RowBox[{"Accuracy", "[", "res", "]"}], " ", "<", " ", 
            RowBox[{"Accuracy", "[", 
             RowBox[{"{", 
              RowBox[{"\[Gamma]", ",", " ", "\[Theta]", ",", " ", "\[Phi]"}], 
              "}"}], "]"}]}]}], ",", " ", 
          RowBox[{"Message", "[", 
           RowBox[{"SpinWeightedSpheroidalHarmonicS", "::", "prec"}], "]"}]}],
          "]"}], ";", "\n", "\n", "  ", "res"}]}], "\n", "]"}], " ", "/;", 
     " ", 
     RowBox[{"method", " ", "==", " ", "\"\<Leaver\>\""}]}]}], ";"}], 
  "\n"}]], "Code",
