Cell[CellGroupData[{

Cell["Spherical expansion method", "Subsubsection",ExpressionUUID->"5cda1ee5-9da9-45d6-9dc2-169bce7b281b"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Options", "[", "SWSHEigenvalueSpectral", "]"}], " ", "=", " ", 
   RowBox[{"{", 
    RowBox[{"\"\<NumTerms\>\"", " ", "->", " ", "Automatic"}], "}"}]}], 
  ";"}]], "Code",
 CellLabel->"In[31]:=",ExpressionUUID->"9fd18918-9817-4d4c-9df9-25dce4aeb93d"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"SWSHEigenvalueSpectral", "[", 
     RowBox[{
     "s_", ",", " ", "l_", ",", " ", "m_", ",", " ", "\[Gamma]_", ",", " ", 
      RowBox[{"OptionsPattern", "[", "]"}]}], "]"}], ":=", "\n", " ", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "nDown", ",", " ", "nUp", ",", " ", "Matrix", ",", " ", "Eigens", ",", 
        " ", "lmin"}], "}"}], ",", "\n", "  ", 
      RowBox[{"(*", " ", 
       RowBox[{"FIXME", ":", " ", 
        RowBox[{"Improve", " ", "the", " ", "estimate", " ", "of", " ", 
         RowBox[{"nmax", ".", " ", "It"}], " ", "should", " ", "depend", " ", 
         "on", " ", "the", " ", "accuarcy", " ", 
         RowBox[{"sought", "."}]}]}], " ", "*)"}], "\n", "  ", 
      RowBox[{
       RowBox[{"Switch", "[", 
        RowBox[{
         RowBox[{"OptionValue", "[", "\"\<NumTerms\>\"", "]"}], ",", "\n", 
         "   ", "Automatic", ",", "\n", "    ", 
         RowBox[{
          RowBox[{"nUp", " ", "=", " ", 
           RowBox[{
            RowBox[{"Ceiling", "[", 
             RowBox[{"Abs", "[", 
              RowBox[{
               RowBox[{"3", "/", "2"}], "\[Gamma]"}], "]"}], "]"}], "+", 
            "5"}]}], ";", "\n", "    ", 
          RowBox[{"Message", "[", 
           RowBox[{
            RowBox[{"SpinWeightedSpheroidalEigenvalue", "::", "numterms"}], 
            ",", " ", "nUp"}], "]"}], ";"}], ",", "\n", "   ", "_Integer", 
         ",", "\n", "    ", 
         RowBox[{
          RowBox[{"nUp", " ", "=", " ", 
           RowBox[{"OptionValue", "[", "\"\<NumTerms\>\"", "]"}]}], ";"}], 
         ",", "\n", "   ", "_", ",", "\n", "    ", 
         RowBox[{
          RowBox[{"Message", "[", 
           RowBox[{
            RowBox[{"SpinWeightedSpheroidalEigenvalue", "::", "optx"}], ",", 
            " ", 
            RowBox[{"Method", " ", "->", " ", 
             RowBox[{"{", 
              RowBox[{"\"\<SphericalExpansion\>\"", ",", " ", "opts"}], 
              "}"}]}]}], "]"}], ";", "\n", "    ", 
          RowBox[{"Return", "[", "$Failed", "]"}], ";"}]}], "\n", "  ", "]"}],
        ";", "\n", "  ", 
       RowBox[{"lmin", "=", 
        RowBox[{"Max", "[", 
         RowBox[{
          RowBox[{"Abs", "[", "s", "]"}], ",", 
          RowBox[{"Abs", "[", "m", "]"}]}], "]"}]}], ";", "\n", "  ", 
       RowBox[{"nDown", " ", "=", " ", 
        RowBox[{"Min", "[", 
         RowBox[{"nUp", ",", " ", 
          RowBox[{"l", "-", "lmin"}]}], "]"}]}], ";", "\n", "\n", "  ", 
       RowBox[{"Matrix", "=", 
        RowBox[{"SparseArray", "[", "\n", "\t", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{
             RowBox[{"{", 
              RowBox[{"i_", ",", "i_"}], "}"}], ":>", 
             RowBox[{"kHat", "[", 
              RowBox[{"s", ",", 
               RowBox[{"l", "-", "nDown", "-", "1", "+", "i"}], ",", "m", ",",
                "\[Gamma]"}], "]"}]}], ",", "\n", "\t", 
            RowBox[{
             RowBox[{
              RowBox[{"{", 
               RowBox[{"i_", ",", "j_"}], "}"}], "/;", 
              RowBox[{
               RowBox[{"j", "-", "i"}], "==", 
               RowBox[{"-", "2"}]}]}], ":>", 
             RowBox[{"k2", "[", 
              RowBox[{"s", ",", 
               RowBox[{"l", "-", "nDown", "-", "3", "+", "i"}], ",", "m", ",",
                "\[Gamma]"}], "]"}]}], ",", "\n", "\t", 
            RowBox[{
             RowBox[{
              RowBox[{"{", 
               RowBox[{"i_", ",", "j_"}], "}"}], "/;", 
              RowBox[{
               RowBox[{"j", "-", "i"}], "==", 
               RowBox[{"-", "1"}]}]}], ":>", 
             RowBox[{"kTilde2", "[", 
              RowBox[{"s", ",", 
               RowBox[{"l", "-", "nDown", "+", "i", "-", "2"}], ",", "m", ",",
                "\[Gamma]"}], "]"}]}], ",", "\n", "\t", 
            RowBox[{
             RowBox[{
              RowBox[{"{", 
               RowBox[{"i_", ",", "j_"}], "}"}], "/;", 
              RowBox[{
               RowBox[{"j", "-", "i"}], "==", "1"}]}], ":>", 
             RowBox[{"kTilde2", "[", 
              RowBox[{"s", ",", 
               RowBox[{"l", "-", "nDown", "+", "i", "-", "1"}], ",", "m", ",",
                "\[Gamma]"}], "]"}]}], ",", "\n", "\t", 
            RowBox[{
             RowBox[{
              RowBox[{"{", 
               RowBox[{"i_", ",", "j_"}], "}"}], "/;", 
              RowBox[{
               RowBox[{"j", "-", "i"}], "==", "2"}]}], ":>", 
             RowBox[{"k2", "[", 
              RowBox[{"s", ",", 
               RowBox[{"l", "-", "nDown", "+", "i", "+", 
                RowBox[{"-", "1"}]}], ",", "m", ",", "\[Gamma]"}], "]"}]}]}], 
           "}"}], "\n", "  ", ",", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"nUp", "+", "nDown", "+", "1"}], ",", 
            RowBox[{"nUp", "+", "nDown", "+", "1"}]}], "}"}]}], "]"}]}], ";", 
       "\n", "\n", "  ", 
       RowBox[{"(*", " ", 
        RowBox[{
         RowBox[{
         "To", " ", "choose", " ", "the", " ", "eigenvalue", " ", 
          "corrsponding", " ", "to", " ", "the", " ", "desired", " ", "l"}], 
         ",", " ", 
         RowBox[{
         "we", " ", "assume", " ", "that", " ", "the", " ", "real", "\n", 
          "     ", "part", " ", "of", " ", "eigenvalue", " ", "is", " ", "a", 
          " ", "monotonic", " ", "function", " ", "of", " ", 
          RowBox[{"l", "."}]}]}], " ", "*)"}], "\n", "  ", 
       RowBox[{"Eigens", "=", 
        RowBox[{"-", 
         RowBox[{"Sort", "[", 
          RowBox[{"Quiet", "[", 
           RowBox[{
            RowBox[{"Eigenvalues", "[", "Matrix", "]"}], ",", 
            RowBox[{"Eigenvalues", "::", "arhm"}]}], "]"}], "]"}]}]}], ";", 
       "\n", "\n", "  ", 
       RowBox[{
        RowBox[{"Eigens", "[", 
         RowBox[{"[", 
          RowBox[{"-", 
           RowBox[{"(", 
            RowBox[{"nDown", "+", "1"}], ")"}]}], "]"}], "]"}], "-", 
        RowBox[{"s", 
         RowBox[{"(", 
          RowBox[{"s", "+", "1"}], ")"}]}]}]}]}], "\n", "]"}]}], ";"}], 
  "\n"}]], "Code",
