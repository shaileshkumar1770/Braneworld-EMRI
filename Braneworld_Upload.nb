Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"SpinWeightedSpheroidalEigenvalue", "[", 
     RowBox[{"s_", ",", " ", "l_", ",", " ", "m_", ",", " ", 
      RowBox[{"\[Gamma]_", "?", "InexactNumberQ"}], ",", " ", 
      RowBox[{"OptionsPattern", "[", "]"}]}], "]"}], " ", "/;", " ", 
    RowBox[{"AllTrue", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"2", "s"}], ",", " ", 
        RowBox[{"2", "l"}], ",", " ", 
        RowBox[{"2", "m"}]}], "}"}], ",", " ", "IntegerQ"}], "]"}]}], " ", ":=",
    " ", "\n", " ", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"opts", ",", " ", "Aini", ",", " ", "\[Lambda]"}], "}"}], ",", 
     "\n", "  ", 
     RowBox[{
      RowBox[{"Switch", "[", 
       RowBox[{
        RowBox[{"OptionValue", "[", "Method", "]"}], ",", "\n", "    ", 
        "\"\<SphericalExpansion\>\"", ",", "\n", "      ", 
        RowBox[{"\[Lambda]", " ", "=", " ", 
         RowBox[{
          RowBox[{"SWSHEigenvalueSpectral", "[", 
           RowBox[{"s", ",", " ", "l", ",", " ", "m", ",", " ", "\[Gamma]"}], 
           "]"}], " ", "-", " ", 
          RowBox[{"2", " ", "m", " ", "\[Gamma]"}], " ", "+", " ", 
          RowBox[{"\[Gamma]", "^", "2"}]}]}], ",", "\n", "    ", 
        RowBox[{"{", 
         RowBox[{"\"\<SphericalExpansion\>\"", ",", " ", 
          RowBox[{
           RowBox[{"Rule", "[", 
            RowBox[{"_", ",", "_"}], "]"}], "..."}]}], "}"}], ",", "\n", 
        "      ", 
        RowBox[{
         RowBox[{"opts", " ", "=", " ", 
          RowBox[{"FilterRules", "[", 
           RowBox[{
            RowBox[{"Rest", "[", 
             RowBox[{"OptionValue", "[", "Method", "]"}], "]"}], ",", " ", 
            RowBox[{"Options", "[", "SWSHEigenvalueSpectral", "]"}]}], 
           "]"}]}], ";", "\n", "      ", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"opts", " ", "=!=", " ", 
            RowBox[{"Rest", "[", 
             RowBox[{"OptionValue", "[", "Method", "]"}], "]"}]}], ",", "\n", 
           "        ", 
           RowBox[{
            RowBox[{"Message", "[", 
             RowBox[{
              RowBox[{"SpinWeightedSpheroidalEigenvalue", "::", "optx"}], ",",
               " ", 
              RowBox[{"Method", " ", "->", " ", 
               RowBox[{"OptionValue", "[", "Method", "]"}]}]}], "]"}], 
            ";"}]}], "\n", "      ", "]"}], ";", "\n", "      ", 
         RowBox[{"\[Lambda]", " ", "=", " ", 
          RowBox[{
           RowBox[{"SWSHEigenvalueSpectral", "[", 
            RowBox[{
            "s", ",", " ", "l", ",", " ", "m", ",", " ", "\[Gamma]", ",", " ",
              "opts"}], "]"}], " ", "-", " ", 
           RowBox[{"2", " ", "m", " ", "\[Gamma]"}], " ", "+", " ", 
           RowBox[{"\[Gamma]", "^", "2"}]}]}]}], ",", "\n", "    ", 
        RowBox[{"Automatic", " ", "|", " ", "\"\<Leaver\>\""}], ",", "\n", 
        "      ", 
        RowBox[{
         RowBox[{"\[Lambda]", " ", "=", " ", 
          RowBox[{
           RowBox[{"SWSHEigenvalueLeaver", "[", 
            RowBox[{"s", ",", " ", "l", ",", " ", "m", ",", " ", "\[Gamma]"}],
             "]"}], " ", "-", " ", 
           RowBox[{"2", " ", "m", " ", "\[Gamma]"}], " ", "+", " ", 
           RowBox[{"\[Gamma]", "^", "2"}]}]}], ";"}], ",", "\n", "    ", 
        RowBox[{"{", 
         RowBox[{"\"\<Leaver\>\"", ",", " ", 
          RowBox[{
           RowBox[{"Rule", "[", 
            RowBox[{"_", ",", "_"}], "]"}], "..."}]}], "}"}], ",", "\n", 
        "      ", 
        RowBox[{
         RowBox[{"opts", " ", "=", " ", 
          RowBox[{"FilterRules", "[", 
           RowBox[{
            RowBox[{"Rest", "[", 
             RowBox[{"OptionValue", "[", "Method", "]"}], "]"}], ",", " ", 
            RowBox[{"Options", "[", "SWSHEigenvalueLeaver", "]"}]}], "]"}]}], 
         ";", "\n", "      ", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"opts", " ", "=!=", " ", 
            RowBox[{"Rest", "[", 
             RowBox[{"OptionValue", "[", "Method", "]"}], "]"}]}], ",", "\n", 
           "        ", 
           RowBox[{
            RowBox[{"Message", "[", 
             RowBox[{
              RowBox[{"SpinWeightedSpheroidalEigenvalue", "::", "optx"}], ",",
               " ", 
              RowBox[{"Method", " ", "->", " ", 
               RowBox[{"OptionValue", "[", "Method", "]"}]}]}], "]"}], 
            ";"}]}], "\n", "      ", "]"}], ";", "\n", "      ", 
         RowBox[{"\[Lambda]", " ", "=", " ", 
          RowBox[{
           RowBox[{"SWSHEigenvalueLeaver", "[", 
            RowBox[{
            "s", ",", " ", "l", ",", " ", "m", ",", " ", "\[Gamma]", ",", " ",
              "opts"}], "]"}], " ", "-", " ", 
           RowBox[{"2", " ", "m", " ", "\[Gamma]"}], " ", "+", " ", 
